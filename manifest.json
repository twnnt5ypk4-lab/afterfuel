  // 1RM Formulas — Epley (1985) & Brzycki (1993), beide gemeinfrei
  function calc1RM(weight, reps) {
    if (reps === 1) return { epley: weight, brzycki: weight, avg: weight };
    const epley   = weight * (1 + reps / 30);
    const brzycki = reps <= 10 ? weight / (1.0278 - 0.0278 * reps) : epley; // Brzycki divergiert >10
    const avg     = (epley + brzycki) / 2;
    return { epley: Math.round(epley), brzycki: Math.round(brzycki), avg: Math.round(avg) };
  }

  // Plausibilitäts-Check für Krafttraining
  function getStrengthPlausibility(liftKg, bodyKg, reps, sets, exercise) {
    const warnings = [];
    // Gewicht/Körpergewicht-Verhältnisse — grobe Richtwerte für Fortgeschrittene
    const highRatios = { squat:2.5, bench:1.8, deadlift:3.0, ohp:1.2, row:1.5, other:2.5 };
    const ratio = liftKg / bodyKg;
    if (ratio > (highRatios[exercise] || 2.5)) {
      warnings.push(`Das Verhältnis Hubgewicht/Körpergewicht (${ratio.toFixed(1)}×) ist für ${getExerciseName(exercise)} ungewöhnlich hoch. Bitte Gewicht oder Körpergewicht prüfen.`);
    }
    if (reps > 20) {
      warnings.push('Bei über 20 Wiederholungen ist die 1RM-Schätzung sehr unzuverlässig. Für eine gute Schätzung am besten 3–8 Wdh. verwenden.');
    }
    if (reps > 10 && reps <= 20) {
      warnings.push('Bei mehr als 10 Wiederholungen nimmt die Genauigkeit der 1RM-Schätzung deutlich ab. Brzycki-Formel wird hier nicht mehr angewendet.');
    }
    if (sets > 20) {
      warnings.push(`${sets} Sätze ist ungewöhnlich viel für eine Übung. Bitte prüfen.`);
    }
    if (liftKg < 10) {
      warnings.push('Das Hubgewicht wirkt sehr niedrig. Bitte prüfen.');
    }
    return warnings;
  }

  function getExerciseName(ex) {
    return { squat:'Kniebeuge', bench:'Bankdrücken', deadlift:'Kreuzheben', ohp:'Schulterdrücken', row:'Rudern', other:'dieser Übung' }[ex] || 'dieser Übung';
  }

  // Trainingszonen nach % 1RM (Standardbereiche der Krafttrainingspraxis)
  function renderStrengthZones(oneRM) {
    const zones = [
      { n:'Kraft',       pct:'85–100 %', lo:0.85, hi:1.00, reps:'1–5',  desc:'Maximalkraft & neuronale Anpassung' },
      { n:'Kraft-Hyp.',  pct:'75–85 %',  lo:0.75, hi:0.85, reps:'4–8',  desc:'Stärke + Muskelaufbau kombiniert' },
      { n:'Hypertrophie',pct:'65–75 %',  lo:0.65, hi:0.75, reps:'8–12', desc:'Muskelaufbau (optimaler Bereich)' },
      { n:'Ausdauer-K.', pct:'55–65 %',  lo:0.55, hi:0.65, reps:'12–20',desc:'Muskelausdauer & Technik' },
    ];
    const rows = zones.map(z => `
      <div class="power-zone-row">
        <div class="power-zone-name">${z.n}</div>
        <div class="power-zone-desc">${z.desc} · ${z.reps} Wdh.</div>
        <div class="power-zone-watts">${Math.round(oneRM * z.lo)}–${Math.round(oneRM * z.hi)} kg</div>
      </div>`).join('');
    return `<div class="power-zones-title">Trainingszonen nach 1RM (${oneRM} kg)</div>${rows}
      <div class="tool-small-note">Richtwerte für klassisches Krafttraining. Prilepin-Empfehlung: Bei 70–80 % insgesamt 12–24 Wdh. pro Einheit; bei 80–90 % eher 10–20 Wdh. gesamt.</div>`;
  }

  function getStrengthInterpretation(oneRM, bodyKg, exercise, sets, reps) {
    const ratio = Math.round((oneRM / bodyKg) * 100) / 100;
    const exName = getExerciseName(exercise);
    // Einordnung nach Körpergewichts-Verhältnis
    let level = '';
    const benchmarks = {
      squat:    [0.75, 1.25, 1.75, 2.25],
      bench:    [0.50, 0.80, 1.25, 1.60],
      deadlift: [1.00, 1.50, 2.00, 2.50],
      ohp:      [0.35, 0.55, 0.80, 1.00],
      row:      [0.50, 0.80, 1.10, 1.40],
      other:    [0.50, 0.90, 1.40, 1.80],
    };
    const b = benchmarks[exercise] || benchmarks.other;
    if (ratio >= b[3])      level = `Sehr starkes Niveau für ${exName} (${ratio}× Körpergewicht).`;
    else if (ratio >= b[2]) level = `Fortgeschrittenes Niveau (${ratio}× KG). Solide Kraftbasis.`;
    else if (ratio >= b[1]) level = `Gutes Mittelniveau für ${exName} (${ratio}× KG).`;
    else if (ratio >= b[0]) level = `Einsteiger- bis Mittelniveau (${ratio}× KG). Viel Potenzial nach oben.`;
    else                    level = `Frühes Trainingsstadium (${ratio}× KG). Regelmäßigkeit bringt schnelle Fortschritte.`;

    // Volumen-Hinweis (grob nach Prilepin)
    const totalReps = (sets || 1) * reps;
    let volNote = '';
    if (totalReps < 10)       volNote = 'Geringes Volumen — gut für schwere Maximalkraft-Tage.';
    else if (totalReps <= 25) volNote = 'Solides Trainingsvolumen für diese Einheit.';
    else if (totalReps <= 40) volNote = 'Hohes Volumen — stelle sicher, dass Erholung und Protein stimmen.';
    else                      volNote = 'Sehr hohes Gesamtvolumen. Achte auf ausreichend Protein und Schlaf.';

    return `<strong>Einordnung ${exName}</strong><br>${level}<br><br>` +
      `<strong>Volumen:</strong> ${sets || '?'} Sätze × ${reps} Wdh. = ${totalReps} Gesamtwdh. — ${volNote}<br><br>` +
      `<strong>Fuel-Hinweis:</strong><br>` +
      `Krafttraining schädigt Muskelfasern kontrolliert — Protein ist jetzt der entscheidende Baustein. ` +
      `Ziel: ~${Math.round(bodyKg * 0.4)}–${Math.round(bodyKg * 0.5)} g Protein in den nächsten 2 Stunden. ` +
      `Kohlenhydrate spielen eine kleinere Rolle als bei Ausdauer, helfen aber beim Wiederauffüllen der Glykogenspeicher.`;
  }

  function calculateStrengthTool() {
    const bodyKg    = +(document.getElementById('stWeight').value || 0);
    const liftKg    = +(document.getElementById('stLiftWeight').value || 0);
    const reps      = +(document.getElementById('stReps').value || 0);
    const sets      = +(document.getElementById('stSets').value || 0);

    const results   = document.getElementById('stResults');
    const zones     = document.getElementById('stZones');
    const interp    = document.getElementById('stInterpretation');
    const warning   = document.getElementById('stWarning');
    const disc      = document.getElementById('stDisclaimer');

    if (!liftKg || !reps) {
      results.innerHTML = '<div style="color:var(--muted);font-size:13px;">Bitte mindestens Hubgewicht und Wiederholungen eingeben.</div>';
      results.classList.remove('hidden');
      zones.classList.add('hidden');
      interp.classList.add('hidden');
      warning.classList.add('hidden');
      disc.classList.add('hidden');
      return;
    }

    // Plausibilitäts-Check
    const plausWarnings = bodyKg > 0
      ? getStrengthPlausibility(liftKg, bodyKg, reps, sets, stExercise)
      : (reps > 20 ? ['Bei über 20 Wiederholungen ist die 1RM-Schätzung sehr unzuverlässig.'] : []);

    if (plausWarnings.length) {
      warning.innerHTML = '<strong>⚠️ Plausibilitätscheck</strong><br>' + plausWarnings.join('<br>');
      warning.classList.remove('hidden');
    } else {
      warning.classList.add('hidden');
    }

    const { epley, brzycki, avg } = calc1RM(liftKg, reps);
    const pctOfMax = Math.round((liftKg / avg) * 100);

    // Aktuelle Zone ermitteln
    let currentZone = 'Ausdauer-Kraft';
    if (pctOfMax >= 85)      currentZone = 'Maximalkraft';
    else if (pctOfMax >= 75) currentZone = 'Kraft-Hypertrophie';
    else if (pctOfMax >= 65) currentZone = 'Hypertrophie';

    // Kalorienverbrauch grob (MET ~5 für Krafttraining, Dauer schätzen aus Sätzen)
    const estMinutes = sets > 0 ? sets * 4 : reps * 1.5; // ~4 min/Satz inkl. Pause
    const kcal = bodyKg > 0 ? Math.round(5.0 * bodyKg * (estMinutes / 60)) : null;

    const ratioStr = bodyKg > 0 ? `${Math.round(avg / bodyKg * 100) / 100}× KG` : '–';

    results.innerHTML = `
      <div class="tool-result">
        <div class="tool-result-label">Max. Schätzung</div>
        <div class="tool-result-value">${epley} kg</div>
        <div class="tool-result-sub">aus ${liftKg} kg × ${reps} Wdh. (Epley)</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">Konservativ</div>
        <div class="tool-result-value">${reps <= 10 ? brzycki + ' kg' : '–'}</div>
        <div class="tool-result-sub">${reps <= 10 ? 'etwas vorsichtiger (Brzycki)' : 'n/a bei >10 Wdh.'}</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">Geschätztes Maximum</div>
        <div class="tool-result-value">${avg} kg</div>
        <div class="tool-result-sub">${ratioStr} · Basis für Zonen unten</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">Heutige Intensität</div>
        <div class="tool-result-value">${pctOfMax} %</div>
        <div class="tool-result-sub">des geschätzten Max. · ${currentZone}</div>
      </div>
      ${kcal ? `<div class="tool-result">
        <div class="tool-result-label">Kalorienverbrauch</div>
        <div class="tool-result-value">~${kcal}</div>
        <div class="tool-result-sub">kcal grob · ~${Math.round(estMinutes)} Min. geschätzt</div>
      </div>` : ''}
      ${sets > 0 ? `<div class="tool-result">
        <div class="tool-result-label">Gesamtvolumen</div>
        <div class="tool-result-value">${sets * reps}</div>
        <div class="tool-result-sub">Wdh. total · ${Math.round(sets * reps * liftKg / 1000 * 10) / 10} t Tonnage</div>
      </div>` : ''}`;
    results.classList.remove('hidden');

    // Sicherheitshinweis — immer sichtbar nach Berechnung
    let safetyBox = document.getElementById('stSafetyNote');
    if (!safetyBox) {
      safetyBox = document.createElement('div');
      safetyBox.id = 'stSafetyNote';
      safetyBox.className = 'cycling-warning';
      safetyBox.style.marginTop = '12px';
      results.after(safetyBox);
    }
    safetyBox.innerHTML = '<strong>⚠️ Geschätztes Maximum ≠ Trainingsgewicht</strong><br>' +
      'Dieser Wert ist eine rechnerische Obergrenze — <strong>nicht direkt ausprobieren.</strong> ' +
      'Echte Maximalversuche erfordern aufgewärmte Muskeln, saubere Technik und einen Spotter oder Sicherheitsvorkehrungen (Multipresse, Safety Pins). ' +
      'Ohne Erfahrung mit schweren Einzelwiederholungen: bitte nicht ohne Aufsicht.';
    zones.classList.remove('hidden');

    if (bodyKg > 0) {
      interp.innerHTML = getStrengthInterpretation(avg, bodyKg, stExercise, sets, reps);
      interp.classList.remove('hidden');
    } else {
      interp.classList.add('hidden');
    }

    disc.classList.remove('hidden');
    document.getElementById('stScience').classList.remove('hidden');
  }

  // ── Globaler Plausibilitäts-Check (Wizard) ──
  function runGlobalPlausibility() {
    const weight   = +(document.getElementById('weight')?.value || 0);
    const height   = +(document.getElementById('height')?.value || 0);
    const age      = +(document.getElementById('age')?.value || 0);
    const dur      = +(document.getElementById('durationMinutes')?.value || 0);
    const intensity = +(document.getElementById('intensity')?.value || 3);

    const warnings = [];

    // BMI-Check
    if (weight > 0 && height > 0) {
      const bmi = weight / ((height / 100) ** 2);
      if (bmi < 13)       warnings.push('Gewicht/Größe-Kombination ergibt einen sehr niedrigen BMI — bitte prüfen.');
      else if (bmi > 55)  warnings.push('Gewicht/Größe-Kombination ergibt einen sehr hohen BMI — bitte prüfen.');
    }

    // Alter vs. Intensität
    if (age > 0 && intensity >= 5 && age >= 65) {
      warnings.push('Sehr hohe Intensität (5) im Alter über 65 — möglich, aber bitte sicherstellen, dass die Eingabe stimmt.');
    }

    // Dauer vs. Intensität
    if (dur > 0 && intensity >= 5 && dur > 120) {
      warnings.push(`${dur} Minuten bei maximaler Intensität (5) ist physiologisch sehr außergewöhnlich. Dauer oder Intensität prüfen.`);
    }
    if (dur > 480) {
      warnings.push('Über 8 Stunden Training — bitte Dauer prüfen oder Ultra-Einheit bewusst eingeben.');
    }

    // Plausibilitäts-Box (nur im Wizard sichtbar)
    let box = document.getElementById('globalPlausibilityBox');
    if (!box) {
      box = document.createElement('div');
      box.id = 'globalPlausibilityBox';
      box.className = 'cycling-warning hidden';
      box.style.marginBottom = '12px';
      const card = document.querySelector('#step3 .card');
      if (card) card.prepend(box);
    }

    if (warnings.length) {
      box.innerHTML = '<strong>⚠️ Plausibilitätscheck</strong><br>' + warnings.join('<br>');
      box.classList.remove('hidden');
    } else {
      box.classList.add('hidden');
    }
  }

  // Plausibilitäts-Check live auf Step 1 & 3 Eingaben
  window.addEventListener('load', () => {
    ['weight','height','age'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', runGlobalPlausibility);
    });
    document.getElementById('durationMinutes')?.addEventListener('input', runGlobalPlausibility);
    document.getElementById('intensity')?.addEventListener('input', runGlobalPlausibility);
  });

  function switchRunMode(mode) {
    runMode = mode;
    document.getElementById('rtPanelRace').classList.toggle('hidden', mode !== 'race');
    document.getElementById('rtPanelPace').classList.toggle('hidden', mode !== 'pace');
    document.getElementById('rtModeRace').classList.toggle('selected', mode === 'race');
    document.getElementById('rtModePace').classList.toggle('selected', mode === 'pace');
    // Reset results
    ['rtResults','rtZones','rtInterpretation','rtDisclaimer'].forEach(id => document.getElementById(id).classList.add('hidden'));
  }

  function updatePaceLabel() {
    const m = +(document.getElementById('rtPaceMinKm').value || 0);
    const s = +(document.getElementById('rtPaceSecKm').value || 0);
    const disp = document.getElementById('rtPaceDisplay');
    if (!m && !s) { disp.textContent = ''; return; }
    const totalSec = m * 60 + s;
    const kmh = totalSec > 0 ? (3600 / totalSec).toFixed(1) : '–';
    disp.textContent = `Entspricht: ${kmh} km/h`;
  }

  // VDOT-Berechnung nach Jack Daniels (vereinfachte Näherung)
  function calcVDOT(distM, timeSec) {
    // % VO₂max aus Pace: Daniels-Formel
    const vel = (distM / timeSec) * 60; // m/min
    const pctVO2 = 0.8 + 0.1894393 * Math.exp(-0.012778 * (timeSec / 60)) + 0.2989558 * Math.exp(-0.1932605 * (timeSec / 60));
    const vo2 = (-4.60 + 0.182258 * vel + 0.000104 * vel * vel) / pctVO2;
    return Math.round(vo2 * 10) / 10;
  }

  // Pace für gegebene % VO₂max → sec/km
  function vo2PctToPaceSecKm(vo2max, pct) {
    // Invertierte Daniels-Näherung: vel (m/min) aus VO₂ (ml/kg/min)
    const vo2target = vo2max * pct;
    // vel: näherungsweise aus quadratischer Formel
    // 0.000104*v^2 + 0.182258*v - 4.60 = vo2target
    const a = 0.000104, b = 0.182258, c = -4.60 - vo2target;
    const vel = (-b + Math.sqrt(b * b - 4 * a * c)) / (2 * a); // m/min
    const secKm = vel > 0 ? Math.round(60000 / vel) : null;
    return secKm;
  }

  function secKmToStr(secKm) {
    if (!secKm || secKm <= 0) return '–';
    const m = Math.floor(secKm / 60);
    const s = secKm % 60;
    return `${m}:${String(s).padStart(2, '0')} /km`;
  }

  function renderRunningZones(vo2max, hfmax) {
    const zones = [
      { n:'E', d:'Easy / Grundlage',    pctLo:0.59, pctHi:0.74, hfPctLo:0.65, hfPctHi:0.79 },
      { n:'M', d:'Marathon-Pace',        pctLo:0.75, pctHi:0.84, hfPctLo:0.80, hfPctHi:0.87 },
      { n:'T', d:'Threshold',            pctLo:0.83, pctHi:0.88, hfPctLo:0.87, hfPctHi:0.92 },
      { n:'I', d:'Intervall VO₂max',     pctLo:0.97, pctHi:1.00, hfPctLo:0.97, hfPctHi:1.00 },
      { n:'R', d:'Repetition / Speed',   pctLo:1.05, pctHi:1.15, hfPctLo:null, hfPctHi:null },
    ];

    const showHf = hfmax && hfmax > 100;
    const hfColHeader = showHf ? '<div style="text-align:right;font-size:11px;font-weight:600;color:var(--hint);">HF</div>' : '';
    const gridStyle = showHf
      ? 'grid-template-columns: 50px 1fr 110px 80px'
      : 'grid-template-columns: 50px 1fr 110px';

    const rows = zones.map(z => {
      const pLo = secKmToStr(vo2PctToPaceSecKm(vo2max, z.pctHi));
      const pHi = secKmToStr(vo2PctToPaceSecKm(vo2max, z.pctLo));
      const hfCell = showHf
        ? (z.hfPctLo
            ? `<div class="run-zone-pace" style="font-size:11px;">${Math.round(hfmax * z.hfPctLo)}–${Math.round(hfmax * z.hfPctHi)}</div>`
            : `<div class="run-zone-pace" style="font-size:11px;color:var(--hint);">–</div>`)
        : '';
      return `<div class="run-zone-row" style="${gridStyle}">
        <div class="run-zone-name">${z.n}</div>
        <div class="run-zone-desc">${z.d}</div>
        <div class="run-zone-pace">${pLo} – ${pHi}</div>
        ${hfCell}
      </div>`;
    }).join('');

    const hfHeader = showHf
      ? `<div style="display:grid;${gridStyle};gap:10px;margin-bottom:4px;font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--hint);">
           <div></div><div></div><div style="text-align:right;">Pace /km</div><div style="text-align:right;">HF (bpm)</div>
         </div>`
      : '';

    return `<div class="power-zones-title">Laufzonen nach Daniels${showHf ? ' · inkl. Herzfrequenz' : ' (Pace /km)'}</div>${hfHeader}${rows}`;
  }

  function getRunInterpretation(vo2, weight) {
    let level = '';
    if (vo2 >= 65) level = 'Sehr hohes Niveau — wettkampforientiert oder ambitioniert trainierend.';
    else if (vo2 >= 55) level = 'Gutes bis hohes Niveau. Strukturiertes Training zahlt sich aus.';
    else if (vo2 >= 45) level = 'Solide Ausdauerbasis. Für die meisten Freizeit- und Volksläufe gut aufgestellt.';
    else if (vo2 >= 35) level = 'Gute Grundlage. Regelmäßigkeit und Zone-2-Läufe bringen dich schnell weiter.';
    else level = 'Frühe Laufbasis. Kontinuität ist jetzt das Wichtigste.';

    return `<strong>Einordnung</strong><br>${level}<br><br><strong>Fuel-Hinweis:</strong><br>` +
      'Läufe unter 60 min bei moderater Intensität brauchen meist keine große Carb-Ladung davor — danach Protein und leichte Kohlenhydrate. ' +
      'Über 75 min und/oder Schwelle: Kohlenhydrate vorher und nachher gezielt planen.';
  }

  function calculateRunningRace() {
    const weight = +(document.getElementById('rtWeight').value || 0);
    const dist = +(document.getElementById('rtDist').value || 5000);
    const h = +(document.getElementById('rtTimeH').value || 0);
    const m = +(document.getElementById('rtTimeM').value || 0);
    const s = +(document.getElementById('rtTimeS').value || 0);
    const totalSec = h * 3600 + m * 60 + s;
    const hfmaxInput = +(document.getElementById('rtHfmax').value || 0);
    // Fallback: 220 − Alter (aus Wizard)
    const ageWizard = +(document.getElementById('age')?.value || 0);
    const hfmax = hfmaxInput > 100 ? hfmaxInput : (ageWizard > 0 ? 220 - ageWizard : 0);

    const results = document.getElementById('rtResults');
    const zones = document.getElementById('rtZones');
    const interp = document.getElementById('rtInterpretation');
    const disc = document.getElementById('rtDisclaimer');

    if (totalSec < 30 || dist <= 0) {
      results.innerHTML = '<div style="color:var(--muted);font-size:13px;">Bitte Distanz und Zeit eingeben.</div>';
      results.classList.remove('hidden');
      return;
    }

    const vo2 = calcVDOT(dist, totalSec);
    const paceSecKm = Math.round(totalSec / (dist / 1000));
    const paceStr = secKmToStr(paceSecKm);
    const speedKmh = (dist / totalSec * 3.6).toFixed(1);

    // Kalorienverbrauch schätzen (MET-basiert, Laufen ~9.5 MET, intensitätsabhängig)
    const durationMin = totalSec / 60;
    let kcal = null;
    if (weight > 0) {
      const met = vo2 >= 55 ? 12 : vo2 >= 45 ? 10 : 9;
      kcal = Math.round(met * weight * (durationMin / 60));
    }

    // Wettkampfzeitprognosen (Riegel-Formel: T2 = T1 * (D2/D1)^1.06)
    const riegelRef = totalSec;
    const riegelDist = dist;
    const predict = (d) => {
      const t = riegelRef * Math.pow(d / riegelDist, 1.06);
      const hh = Math.floor(t / 3600);
      const mm = Math.floor((t % 3600) / 60);
      const ss = Math.round(t % 60);
      return hh > 0
        ? `${hh}:${String(mm).padStart(2,'0')}:${String(ss).padStart(2,'0')}`
        : `${mm}:${String(ss).padStart(2,'0')}`;
    };

    const predRows = [5000,10000,21097,42195]
      .filter(d => d !== dist)
      .map(d => {
        const label = d===5000?'5 km':d===10000?'10 km':d===21097?'HM':'Marathon';
        return `<div class="tool-result">
          <div class="tool-result-label">${label}</div>
          <div class="tool-result-value">${predict(d)}</div>
          <div class="tool-result-sub">Prognose (Riegel)</div>
        </div>`;
      }).join('');

    results.innerHTML = `
      <div class="tool-result">
        <div class="tool-result-label">VO₂max</div>
        <div class="tool-result-value">${vo2}</div>
        <div class="tool-result-sub">ml/kg/min (VDOT)</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">Pace</div>
        <div class="tool-result-value">${paceStr.replace(' /km','')}</div>
        <div class="tool-result-sub">min/km · ${speedKmh} km/h</div>
      </div>
      ${kcal ? `<div class="tool-result">
        <div class="tool-result-label">Kalorienverbrauch</div>
        <div class="tool-result-value">~${kcal}</div>
        <div class="tool-result-sub">kcal (MET-Schätzung)</div>
      </div>` : ''}
      ${predRows}`;
    results.classList.remove('hidden');

    zones.innerHTML = renderRunningZones(vo2, hfmax);
    zones.classList.remove('hidden');

    interp.innerHTML = getRunInterpretation(vo2, weight);
    interp.classList.remove('hidden');

    disc.classList.remove('hidden');
    document.getElementById('rtScience').classList.remove('hidden');
  }

  function runningCalcLive() {
    // Nur live rechnen wenn genug Daten da
    const m = +(document.getElementById('rtTimeM').value || 0);
    const dist = +(document.getElementById('rtDist').value || 0);
    if (m > 0 && dist > 0) calculateRunningRace();
  }

  function calculateRunningPace() {
    const weight = +(document.getElementById('rtPaceWeight').value || 0);
    const durMin = +(document.getElementById('rtPaceDur').value || 0);
    const paceM = +(document.getElementById('rtPaceMinKm').value || 0);
    const paceS = +(document.getElementById('rtPaceSecKm').value || 0);
    const hfmaxInput = +(document.getElementById('rtPaceHfmax').value || 0);
    const avgHf = +(document.getElementById('rtPaceAvgHf').value || 0);
    const ageWizard = +(document.getElementById('age')?.value || 0);
    const hfmax = hfmaxInput > 100 ? hfmaxInput : (ageWizard > 0 ? 220 - ageWizard : 0);

    const results = document.getElementById('rtResults');
    const zones = document.getElementById('rtZones');
    const interp = document.getElementById('rtInterpretation');
    const disc = document.getElementById('rtDisclaimer');

    if (!paceM && !paceS) {
      results.innerHTML = '<div style="color:var(--muted);font-size:13px;">Bitte Pace eingeben.</div>';
      results.classList.remove('hidden');
      return;
    }

    const paceSecKm = paceM * 60 + paceS;
    const speedKmh = (3600 / paceSecKm).toFixed(1);
    const distKm = durMin > 0 ? (durMin / paceSecKm * 60).toFixed(2) : null;

    // Grobe VO₂max-Schätzung aus der Pace (wenn keine Wettkampfzeit)
    // Basis: Laufen auf dieser Pace → welcher % VO₂max ist das typischerweise?
    // Annahme: Trainingspace ~ 75% VO₂max (lockerer Lauf)
    const velMmin = 1000 / paceSecKm * 60;
    const vo2atPace = -4.60 + 0.182258 * velMmin + 0.000104 * velMmin * velMmin;
    const vo2EstLow = Math.round(vo2atPace / 0.80 * 10) / 10; // wenn 80% VO₂max
    const vo2EstHigh = Math.round(vo2atPace / 0.65 * 10) / 10; // wenn 65% VO₂max

    // Kalorienverbrauch
    let kcal = null;
    if (weight > 0 && durMin > 0) {
      const met = paceSecKm < 240 ? 14 : paceSecKm < 300 ? 11 : paceSecKm < 360 ? 9.5 : 8;
      kcal = Math.round(met * weight * (durMin / 60));
    }

    // Entkopplungs-Check: Pace-Zone vs. HF-Zone
    let decouplingNote = '';
    if (avgHf > 0 && hfmax > 0) {
      const hfPct = avgHf / hfmax;
      // Pace-Zone aus VO₂-Prozentsatz ermitteln
      const velMmin2 = 1000 / paceSecKm * 60;
      const vo2atPace2 = -4.60 + 0.182258 * velMmin2 + 0.000104 * velMmin2 * velMmin2;
      const vo2pct = vo2atPace2 / ((vo2EstLow + vo2EstHigh) / 2);
      // Erwartete HF-Zone grob: bei ~70% VO₂max → ~80% HFmax
      // Faustregel: HF% ≈ 0.64 + 0.36 * VO₂%
      const expectedHfPct = 0.64 + 0.36 * Math.min(vo2pct, 1.0);
      const diff = hfPct - expectedHfPct;
      if (diff > 0.08) {
        decouplingNote = `⚠️ <strong>HF höher als erwartet</strong> für diese Pace (~${Math.round(expectedHfPct*hfmax)} bpm erwartet, ${avgHf} gemessen). Mögliche Ursachen: Hitze, Erschöpfung, Dehydration, frühe Trainingswoche oder zu wenig Schlaf.`;
      } else if (diff < -0.08) {
        decouplingNote = `✅ <strong>HF niedriger als erwartet</strong> für diese Pace (~${Math.round(expectedHfPct*hfmax)} bpm erwartet, ${avgHf} gemessen). Gut — das deutet auf solide aerobe Effizienz hin.`;
      } else {
        decouplingNote = `✓ <strong>HF und Pace passen gut zusammen</strong> (${avgHf} bpm bei dieser Pace liegt im Normalbereich).`;
      }
    }

    const hfTile = (avgHf > 0 && hfmax > 0) ? `
      <div class="tool-result">
        <div class="tool-result-label">Ø HF</div>
        <div class="tool-result-value">${avgHf}</div>
        <div class="tool-result-sub">${Math.round(avgHf / hfmax * 100)} % HFmax (${hfmax})</div>
      </div>` : '';

    results.innerHTML = `
      <div class="tool-result">
        <div class="tool-result-label">Pace</div>
        <div class="tool-result-value">${paceM}:${String(paceS).padStart(2,'0')}</div>
        <div class="tool-result-sub">min/km · ${speedKmh} km/h</div>
      </div>
      ${distKm ? `<div class="tool-result">
        <div class="tool-result-label">Distanz</div>
        <div class="tool-result-value">${distKm}</div>
        <div class="tool-result-sub">km in ${durMin} Min.</div>
      </div>` : ''}
      <div class="tool-result">
        <div class="tool-result-label">VO₂max (grob)</div>
        <div class="tool-result-value">${vo2EstLow}–${vo2EstHigh}</div>
        <div class="tool-result-sub">ml/kg/min, Bandbreite je nach Trainingszone</div>
      </div>
      ${kcal ? `<div class="tool-result">
        <div class="tool-result-label">Kalorienverbrauch</div>
        <div class="tool-result-value">~${kcal}</div>
        <div class="tool-result-sub">kcal (MET-Schätzung)</div>
      </div>` : ''}
      ${hfTile}`;
    results.classList.remove('hidden');

    if (decouplingNote) {
      const existing = document.getElementById('rtDecoupling');
      if (existing) existing.remove();
      const box = document.createElement('div');
      box.id = 'rtDecoupling';
      box.className = 'cycling-note';
      box.style.marginTop = '10px';
      box.innerHTML = decouplingNote;
      results.after(box);
    } else {
      const existing = document.getElementById('rtDecoupling');
      if (existing) existing.remove();
    }

    const vo2mid = Math.round((vo2EstLow + vo2EstHigh) / 2 * 10) / 10;
    zones.innerHTML = renderRunningZones(vo2mid, hfmax);
    zones.classList.remove('hidden');

    interp.innerHTML = getRunInterpretation(vo2mid, weight);
    interp.classList.remove('hidden');

    disc.classList.remove('hidden');
    document.getElementById('rtScience').classList.remove('hidden');
  }


  function renderPowerZones(ftp) {
    const z = [
      { n:'Z1', d:'Recovery / sehr locker', lo:0,    hi:.55 },
      { n:'Z2', d:'Grundlage / Ausdauer',   lo:.56,  hi:.75 },
      { n:'Z3', d:'Tempo',                  lo:.76,  hi:.90 },
      { n:'Z4', d:'Schwelle',               lo:.91,  hi:1.05 },
      { n:'Z5', d:'VO₂max',                 lo:1.06, hi:1.20 },
      { n:'Z6', d:'Anaerob',                lo:1.21, hi:1.50 },
      { n:'Z7', d:'Neuromuskulär / Sprint', lo:1.51, hi:null }
    ];
    return `
      <div class="power-zones-title">Leistungszonen nach FTP</div>
      ${z.map(zone => {
        const low = zone.lo === 0 ? 0 : Math.round(ftp * zone.lo);
        const high = zone.hi ? Math.round(ftp * zone.hi) : null;
        const watts = high ? `${low}–${high} W` : `ab ${low} W`;
        return `<div class="power-zone-row"><div class="power-zone-name">${zone.n}</div><div class="power-zone-desc">${zone.d}</div><div class="power-zone-watts">${watts}</div></div>`;
      }).join('')}
      <div class="tool-small-note">Die Zonen orientieren sich an klassischen FTP-Prozentbereichen. Für lockeres Training ist Z2 meist der wichtigste praktische Bereich.</div>`;
  }

  function calculateCyclingTool() {
    const weight = +document.getElementById('ctWeight').value;
    const knownFtp = +document.getElementById('ctKnownFtp').value;
    const best20 = +document.getElementById('ctBest20').value;
    const results = document.getElementById('ctResults');
    const zonesBox = document.getElementById('ctPowerZones');
    const disclaimer = document.getElementById('ctDisclaimer');

    if (!weight || (!knownFtp && !best20) || weight < 30) {
      results.classList.remove('hidden');
      results.innerHTML = `<div class="tool-result" style="grid-column:1/-1;"><div class="tool-result-label">Hinweis</div><div class="tool-result-sub">Bitte Gewicht und entweder deinen FTP oder eine 20-min-Bestleistung eingeben.</div></div>`;
      if (zonesBox) zonesBox.classList.add('hidden');
      disclaimer.classList.add('hidden');
      return;
    }

    let ftp, ftpNote, confidence;
    if (knownFtp > 0) {
      ftp = Math.round(knownFtp);
      ftpNote = 'vom Nutzer eingegeben';
      confidence = 'Schätzqualität: hoch bei bekanntem FTP';
    } else {
      ftp = Math.round(best20 * 0.95);
      ftpNote = 'aus 95 % deiner 20-min-Leistung';
      confidence = 'Schätzqualität: gut (20-min-Leistung)';
    }

    const mapLow = Math.round(ftp * 1.22);
    const mapHigh = Math.round(ftp * 1.33);
    const mapMid = Math.round((mapLow + mapHigh) / 2);
    const vo2 = Math.round(((10.8 * mapMid / weight) + 7) * 10) / 10;
    const wkg = Math.round((ftp / weight) * 100) / 100;

    results.innerHTML = `
      <div class="tool-result">
        <div class="tool-result-label">FTP</div>
        <div class="tool-result-value">${ftp} W</div>
        <div class="tool-result-sub">${ftpNote}</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">MAP</div>
        <div class="tool-result-value">${mapLow}–${mapHigh}</div>
        <div class="tool-result-sub">W, aus FTP abgeleitet</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">VO₂max</div>
        <div class="tool-result-value">${vo2}</div>
        <div class="tool-result-sub">ml/kg/min, leistungsbasiert</div>
      </div>
      <div class="tool-result">
        <div class="tool-result-label">FTP/kg</div>
        <div class="tool-result-value">${wkg}</div>
        <div class="tool-result-sub">W/kg</div>
      </div>`;
    results.classList.remove('hidden');
    if (zonesBox) {
      zonesBox.innerHTML = renderPowerZones(ftp);
      zonesBox.classList.remove('hidden');
    }
    disclaimer.classList.remove('hidden');
    document.getElementById('ctScience').classList.remove('hidden');

    updateCyclingMethodVisibility(confidence, []);
  }

  function startWizard() {
    window.scrollTo({top: 0, behavior: 'instant'});
    document.getElementById('landing').classList.add('hidden');
    document.getElementById('howItWorks').classList.add('hidden');
    document.getElementById('wizard').classList.remove('hidden');
  }

  function showWeekPreview() {
    renderWeekPreview();
    const wrap = document.getElementById('weekPreviewWrap');
    if (!wrap) return;
    wrap.classList.remove('hidden');
    wrap.scrollIntoView({behavior:'smooth', block:'center'});
  }

  function hideWeekPreview() {
    const wrap = document.getElementById('weekPreviewWrap');
    if (wrap) wrap.classList.add('hidden');
  }

  function renderWeekPreview() {
    const history = loadHistory();
    if (history.length < 2) return;

    const intensityColors = { 0:'#e2dfd9', 1:'#f5ede6', 2:'#f2c4a8', 3:'#e8956d', 4:'#c84b2f', 5:'#2d5a3d' };
    const intensityNames  = { 0:'Ruhetag', 1:'sehr leicht', 2:'leicht', 3:'moderat', 4:'hart', 5:'sehr hart' };
    const days = ['Mo','Di','Mi','Do','Fr','Sa','So'];
    const today = new Date();

    const buckets = Array.from({length:7}, (_,i) => {
      const d = new Date(today);
      d.setDate(today.getDate() - (6-i));
      const dayIdx = d.getDay()===0 ? 6 : d.getDay()-1;
      return { label: days[dayIdx], date: d, intensity: 0, sport: null, isToday: d.toDateString()===today.toDateString() };
    });

    history.forEach(h => {
      const hDate = new Date(h.ts);
      buckets.forEach(b => {
        if (hDate.toDateString() === b.date.toDateString() && h.intensity > b.intensity) {
          b.intensity = h.intensity;
          b.sport = h.sportName;
        }
      });
    });

    const intenseDays = buckets.filter(b => b.intensity >= 4).length;
    const easyDays    = buckets.filter(b => b.intensity >= 1 && b.intensity <= 3).length;
    const restDays    = buckets.filter(b => b.intensity === 0).length;

    // Mini chart
    const chartHTML = buckets.map(b => {
      const barH = b.intensity > 0 ? Math.round((b.intensity/5)*80) : 0;
      const color = intensityColors[b.intensity];
      return `
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;height:100%;justify-content:flex-end;">
          ${b.intensity > 0
            ? `<div style="width:100%;height:${barH}px;background:${color};border-radius:5px 5px 0 0;"></div>`
            : `<div style="width:30%;height:3px;background:var(--border2);border-radius:2px;"></div>`
          }
          <div style="font-size:10px;color:${b.isToday?'var(--accent)':'var(--hint)'};font-weight:${b.isToday?'600':'500'}">${b.label}</div>
        </div>`;
    }).join('');
    const chartEl = document.getElementById('weekPreviewChart');
    if (chartEl) chartEl.innerHTML = chartHTML;

    // Summary
    let summary = '';
    if (intenseDays === 0 && easyDays === 0) summary = 'Diese Woche noch keine Einheiten erfasst.';
    else if (intenseDays === 0) summary = `<strong>${easyDays} lockere Einheiten</strong> diese Woche.`;
    else if (easyDays === 0) summary = `<strong>${intenseDays} intensive Tage</strong> diese Woche.`;
    else summary = `<strong>${intenseDays} intensive</strong> und <strong>${easyDays} lockere</strong> Einheiten diese Woche.`;
    if (restDays >= 1 && restDays <= 2) summary += ' Gute Balance.';
    const summaryEl = document.getElementById('weekPreviewSummary');
    if (summaryEl) summaryEl.innerHTML = summary;
  }

  function reset() {
    goTo(1);
    // Reset rest day
    if (isRestDay) toggleRestDay();
    // Reset second workout
    const old = document.getElementById('secondResult');
    if (old) old.remove();
    document.getElementById('secondForm').classList.add('hidden');
    document.getElementById('secondToggleBtn').textContent = '➕ Zweite Einheit heute hinzufügen';
    document.getElementById('secondToggleBtn').style.borderColor = '';
    document.getElementById('secondToggleBtn').style.color = '';
    document.getElementById('secondWrap').classList.remove('hidden');
    document.getElementById('landing').classList.remove('hidden');
    document.getElementById('howItWorks').classList.remove('hidden');
    document.getElementById('wizard').classList.add('hidden');
    window.scrollTo({top: 0, behavior: 'smooth'});
  }

  // ── Sport Profiles ──
  // system: endurance | interval | strength | mixed | low
  // sweat:  high | mid | low | none
  // muscle: legs | upper | full
  // carbMod: multiplier on top of base carb recommendation
  // protMod: multiplier on protein
  const SPORT_PROFILES = {
    cycling:    { met:6.5,  system:'endurance', sweat:'mid',  muscle:'legs',  carbMod:1.1,  protMod:1.0,  name:'Radfahren' },
    mtb:        { met:7.5,  system:'mixed',     sweat:'high', muscle:'legs',  carbMod:1.15, protMod:1.0,  name:'MTB' },
    running:    { met:9.5,  system:'endurance', sweat:'high', muscle:'legs',  carbMod:1.1,  protMod:1.0,  name:'Laufen' },
    swimming:   { met:7.0,  system:'endurance', sweat:'none', muscle:'full',  carbMod:1.0,  protMod:1.05, name:'Schwimmen' },
    rowing:     { met:7.5,  system:'endurance', sweat:'high', muscle:'full',  carbMod:1.1,  protMod:1.05, name:'Rudern' },
    walking:    { met:3.8,  system:'low',       sweat:'low',  muscle:'legs',  carbMod:0.7,  protMod:0.8,  name:'Gehen / Wandern' },
    strength:   { met:5.0,  system:'strength',  sweat:'low',  muscle:'upper', carbMod:0.75, protMod:1.2,  name:'Krafttraining' },
    climbing:   { met:6.0,  system:'strength',  sweat:'mid',  muscle:'upper', carbMod:0.8,  protMod:1.15, name:'Klettern' },
    crossfit:   { met:8.5,  system:'mixed',     sweat:'high', muscle:'full',  carbMod:1.1,  protMod:1.15, name:'CrossFit' },
    hiit:       { met:9.0,  system:'interval',  sweat:'high', muscle:'full',  carbMod:1.05, protMod:1.05, name:'HIIT' },
    football:   { met:8.0,  system:'interval',  sweat:'high', muscle:'legs',  carbMod:1.1,  protMod:1.0,  name:'Fußball' },
    basketball: { met:7.5,  system:'interval',  sweat:'high', muscle:'full',  carbMod:1.05, protMod:1.0,  name:'Basketball' },
    handball:   { met:8.5,  system:'interval',  sweat:'high', muscle:'full',  carbMod:1.1,  protMod:1.05, name:'Handball' },
    tennis:     { met:7.0,  system:'interval',  sweat:'mid',  muscle:'full',  carbMod:1.0,  protMod:1.0,  name:'Tennis' },
    yoga:       { met:2.5,  system:'low',       sweat:'low',  muscle:'full',  carbMod:0.5,  protMod:0.75, name:'Yoga / Mobility' },
  };

  // ── Meal Database ──
  const MEAL_DB = [
    // Universal
    { t:'Skyr-Bowl', b:'250–300 g Skyr mit Beeren und 30–60 g Haferflocken. Eiweißreich, gut verträglich, schnell zubereitet.', macros:'~25–35 g Protein · ~40–55 g Carbs', score:()=>5 },
    { t:'Proteinshake + Banane', b:'30 g Proteinpulver mit 300 ml Milch und einer Banane. Ideal wenn der Hunger nach dem Training noch fehlt.', macros:'~30–38 g Protein · ~30–40 g Carbs', score:({intensity})=>intensity>=4?8:4 },
    { t:'Magerquark mit Honig & Beeren', b:'300 g Magerquark, 1 TL Honig, Beeren. Casein wirkt langsam — gut für die Nacht nach Abendtraining.', macros:'~32–40 g Protein · ~20–28 g Carbs', score:({goal})=>goal==='build'?7:5 },

    // Ausdauer (cycling, mtb, running, rowing)
    { t:'Reis mit Hähnchen', b:'150–180 g Hähnchenbrust (gegrillt) mit 200 g Reis und Gemüse. Nach langen Ausdauereinheiten die Standardoption.', macros:'~40–50 g Protein · ~55–70 g Carbs', score:({sp,intensity,dur})=>['cycling','mtb','running','rowing'].includes(sp)&&intensity>=3&&dur>=60?10:3 },
    { t:'Kartoffeln mit Quark', b:'250–300 g Pellkartoffeln mit 200 g Magerquark und Kräutern. Klassiker nach Zone-2-Einheiten.', macros:'~22–28 g Protein · ~45–55 g Carbs', score:({sp,goal,intensity})=>['cycling','mtb'].includes(sp)&&goal==='fatloss'&&intensity<=2?9:3 },
    { t:'Pasta mit Thunfisch', b:'150–180 g Pasta mit Thunfisch, Tomaten und Olivenöl. Für lange oder intensive Ausdauereinheiten.', macros:'~35–45 g Protein · ~60–80 g Carbs', score:({sp,goal,intensity})=>['cycling','mtb','running'].includes(sp)&&goal==='build'&&intensity>=4?10:3 },
    { t:'Vollkornbrot mit Ei & Avocado', b:'2–3 Scheiben Vollkornbrot, 2 Eier, ½ Avocado. Nach kurzen Ausdauereinheiten — einfach und ausgewogen.', macros:'~20–26 g Protein · ~35–45 g Carbs', score:({sp,dur})=>['cycling','mtb','running'].includes(sp)&&dur<=60?8:3 },
    { t:'Lachsfilet mit Quinoa', b:'150–180 g Lachs (gebacken) mit 150 g Quinoa und gedünstetem Gemüse. Vollständige Mahlzeit nach langen Einheiten.', macros:'~38–48 g Protein · ~40–55 g Carbs', score:({sp})=>['swimming','rowing'].includes(sp)?10:3 },

    // Krafttraining & Klettern
    { t:'Hüttenkäse mit Vollkornbrot', b:'200 g Hüttenkäse auf 2–3 Scheiben Vollkornbrot mit Tomate und Gurke. Einfach, eiweißreich.', macros:'~24–30 g Protein · ~35–45 g Carbs', score:({sp,goal})=>['strength','climbing'].includes(sp)&&goal==='fatloss'?9:3 },
    { t:'Ei-Wrap mit Gemüse', b:'3–4 Eier als Omelett in einem Vollkorn-Wrap mit Paprika, Tomaten, Spinat. Schnell, hohe Proteinqualität.', macros:'~28–36 g Protein · ~30–40 g Carbs', score:({sp})=>['strength','climbing','crossfit'].includes(sp)?8:3 },
    { t:'Quark-Bowl mit Nüssen', b:'300 g Magerquark, Walnüsse, Beeren und Honig. Casein + gesunde Fette — ideal nach Abendtraining im Gym.', macros:'~32–40 g Protein · ~18–26 g Carbs', score:({sp,goal})=>['strength','climbing'].includes(sp)&&goal==='build'?10:3 },
    { t:'Thunfisch-Wraps', b:'1 Dose Thunfisch in 2 Vollkorn-Wraps mit Salatblättern und Tomate. Schnell, günstig, proteinreich.', macros:'~30–38 g Protein · ~35–45 g Carbs', score:({sp})=>['strength','crossfit'].includes(sp)?7:3 },

    // Mannschaftssport & Intervall (Fußball, Basketball, Handball, Tennis)
    { t:'Reiskuchen mit Quark & Erdnussmus', b:'3–4 Reiskuchen, 2 EL Erdnussmus, 150 g Magerquark. Schnelle Carbs + Protein — ideal nach Intervallsport.', macros:'~22–28 g Protein · ~38–48 g Carbs', score:({sp})=>['football','basketball','handball','tennis','hiit'].includes(sp)?9:3 },
    { t:'Pasta mit Hähnchen-Tomatensoße', b:'150 g Pasta mit 120 g Hähnchen in Tomatensoße. Klassiker nach dem Spiel — Glycogen auffüllen und Protein für die Muskeln.', macros:'~35–42 g Protein · ~55–70 g Carbs', score:({sp,intensity})=>['football','basketball','handball'].includes(sp)&&intensity>=3?10:3 },
    { t:'Bananen-Protein-Smoothie', b:'1 Banane, 200 ml Milch, 30 g Proteinpulver, 1 EL Erdnussmus. Nach intensivem Intervallsport oft schneller verträglich.', macros:'~28–35 g Protein · ~25–40 g Carbs', score:({sp})=>['hiit','crossfit','handball','basketball'].includes(sp)?9:4 },
    { t:'Vollkornbrot mit Pute & Salat', b:'2–3 Scheiben Vollkornbrot, 100 g Putenbrustaufschnitt, Tomate, Gurke. Nach Tennis oder Mannschaftssport — unkompliziert und ausgewogen.', macros:'~26–32 g Protein · ~35–45 g Carbs', score:({sp})=>['tennis','football','basketball'].includes(sp)?8:3 },

    // CrossFit & HIIT
    { t:'Süßkartoffel mit Lachs', b:'200 g Süßkartoffel (gebacken) mit 150 g Lachs. Omega-3 hilft bei Entzündungsreduktion nach harten Einheiten.', macros:'~30–38 g Protein · ~40–50 g Carbs', score:({sp,intensity})=>['crossfit','hiit','running'].includes(sp)&&intensity>=4?10:3 },

    // Schwimmen
    { t:'Bohnen-Tomaten-Pfanne', b:'200 g weiße Bohnen, Kirschtomaten, Knoblauch, Spinat. Pflanzliches Protein, sättigend.', macros:'~18–24 g Protein · ~35–45 g Carbs', score:({sp,intensity})=>sp==='swimming'&&intensity<=2?8:3 },

    // Gehen / Yoga
    { t:'Vollkornbrot mit Käse & Tomate', b:'2–3 Scheiben Vollkornbrot, 60–80 g Käse, Tomate und Gurke. Nach leichten Einheiten — einfach und ausgewogen.', macros:'~18–24 g Protein · ~35–45 g Carbs', score:({sp})=>['walking','yoga'].includes(sp)?9:2 },
    { t:'Linsensuppe', b:'300–400 ml Linsensuppe mit Vollkornbrot. Wärmend, pflanzliches Protein — gut nach Yoga oder langen Wanderungen.', macros:'~16–22 g Protein · ~40–55 g Carbs', score:({sp})=>['walking','yoga'].includes(sp)?8:2 },
    { t:'Griechischer Joghurt mit Granola', b:'250 g griechischer Joghurt, 40 g Granola, etwas Honig. Leicht und gut verträglich nach ruhigen Einheiten.', macros:'~18–24 g Protein · ~35–50 g Carbs', score:({sp,intensity})=>['yoga','walking'].includes(sp)||intensity<=2?7:3 },

    // Ziel-spezifisch
    { t:'Gemüsepfanne mit Ei', b:'Zucchini, Paprika, Brokkoli anbraten, 3–4 Eier dazu. Volumen und Sättigung mit wenig Kalorien.', macros:'~22–28 g Protein · ~15–25 g Carbs', score:({goal})=>goal==='fatloss'?8:2 },
    { t:'Overnight Oats', b:'80 g Haferflocken über Nacht in 200 ml Milch + 30 g Proteinpulver. Ideal nach dem Morgentraining.', macros:'~28–35 g Protein · ~55–70 g Carbs', score:({goal,intensity})=>goal==='build'&&intensity>=3?8:3 },
  ];

  function selectMeals({ sp, goal, intensity, dur }) {
    const scored = MEAL_DB.map(m => ({ ...m, s: m.score({sp,goal,intensity,dur}) }));
    scored.sort((a,b) => b.s - a.s);
    const seen = new Set(), out = [];
    for (const m of scored) { if (out.length>=5) break; if (!seen.has(m.t)) { seen.add(m.t); out.push(m); } }
    return out;
  }

  // ── Core Math ──
  const mealKcal = {
    breakfast:{ none:[0,0], small:[250,400], normal:[400,700], large:[700,1000] },
    lunch:    { none:[0,0], small:[350,550], normal:[600,900], large:[900,1300] },
    dinner:   { none:[0,0], small:[350,550], normal:[600,900], large:[900,1300] },
    snacks:   { none:[0,0], small:[100,250], normal:[250,500], large:[500,900] }
  };
  const iFactor = { 1:.75, 2:.9, 3:1.05, 4:1.25, 5:1.45 };
  const pPerKg  = { 1:.25, 2:.28, 3:.32, 4:.36, 5:.40 };
  const cPerKg  = { 1:.25, 2:.45, 3:.70, 4:.95, 5:1.20 };

  const systemLabels = { endurance:'Ausdauer', interval:'Intervall', strength:'Kraft', mixed:'Gemischt', low:'Leicht' };
  const systemTagClass = { endurance:'tag-endurance', interval:'tag-interval', strength:'tag-strength', mixed:'tag-mixed', low:'tag-low' };

  function calculate() {
    const w   = +document.getElementById('weight').value;
    const h   = +document.getElementById('height').value;
    const a   = +document.getElementById('age').value;
    const s   = document.getElementById('sex').value;
    const dur = +document.getElementById('durationMinutes').value;
    const intensity = +document.getElementById('intensity').value;

    if (!w||!h||!a) return;
    if (!validateAll()) return;

    // ── Rest Day Mode ──
    if (isRestDay) {
      calculateRestDay(w, h, a, s);
      return;
    }

    if (!validateStep3()) return;

    // ── Sinnvolle Obergrenzen ──
    const MAX_KCAL = 4500; // Realistische Obergrenze selbst für Extremsport
    const isExtreme = dur >= 180; // Ab 3 Stunden Hinweis einblenden
    const isUltra   = dur >= 300; // Ab 5 Stunden Ultra-Hinweis

    const sp = SPORT_PROFILES[state.sport];

    const bmrMale   = 10*w+6.25*h-5*a+5;
    const bmrFemale = 10*w+6.25*h-5*a-161;
    const bmr = s==='female' ? bmrFemale : s==='diverse' ? Math.round((bmrMale+bmrFemale)/2) : bmrMale;
    const actF = {sedentary:1.25,normal:1.45,active:1.65}[state.dailyActivity];
    const goalF = {fatloss:.88,maintain:1.0,build:1.08}[state.goal];
    const maint = bmr*actF, target = maint*goalF;
    const targetMin=Math.round(target*.95), targetMax=Math.round(target*1.05);
    const maintMin=Math.round(maint*.95),   maintMax=Math.round(maint*1.05);

    const foodMin = ['breakfast','lunch','dinner','snacks'].reduce((acc,m)=>acc+mealKcal[m][document.getElementById(m).value][0],0);
    const foodMax = ['breakfast','lunch','dinner','snacks'].reduce((acc,m)=>acc+mealKcal[m][document.getElementById(m).value][1],0);

    const kcalRaw = sp.met * w * (dur/60) * iFactor[intensity];
    const kcal    = Math.min(kcalRaw, MAX_KCAL);
    const wMin=Math.round(kcal*.9), wMax=Math.round(kcal*1.1);

    // Short workout detection
    const isShort = dur < 10;

    // Unrealistic intensity/duration combo warning
    const isUnrealisticCombo = intensity === 5 && dur > 45 || intensity === 4 && dur > 90;

    // Apply sport-specific modifiers
    let protein = w * pPerKg[intensity] * sp.protMod;
    let carbs   = w * cPerKg[intensity] * sp.carbMod;
    if (state.goal==='fatloss') carbs*=.75;
    if (state.goal==='build') { protein*=1.08; carbs*=1.15; }

    // Protein minimum — never below 20g regardless of weight/sport
    const pMinRaw = Math.round(protein*.9);
    const pMaxRaw = Math.round(protein*1.1);
    const pMin = Math.max(20, pMinRaw);
    const pMax = Math.max(25, pMaxRaw);
    const cMin=Math.round(carbs*.85), cMax=Math.round(carbs*1.15);

    const compF = {fatloss:.45,maintain:.75,build:.95}[state.goal];
    const adjMin=Math.round(targetMin+wMin*compF), adjMax=Math.round(targetMax+wMax*compF);
    const remMin=adjMin-foodMax, remMax=adjMax-foodMin;
    let status='balanced';
    if (remMax<0) status='above';
    else if (remMin>700) status='low_intake';
    else if (remMin>250) status='room_left';

    // Negative calorie balance warning — very little eaten + hard training
    const veryLowIntake = foodMax < 600 && intensity >= 3;

    lastResult = { wMin,wMax,pMin,pMax,cMin,cMax,sport:state.sport,sportName:sp.name,goal:state.goal,intensity,dur,status };

    // ── Fill Metrics ──
    document.getElementById('rWorkout').textContent = wMin+'–'+wMax+' kcal';
    document.getElementById('rProtein').textContent = pMin+'–'+pMax+' g';
    document.getElementById('rCarbs').textContent   = cMin+'–'+cMax+' g';
    document.getElementById('resultSub').innerHTML  =
      `<span class="sport-tag ${systemTagClass[sp.system]}">${systemLabels[sp.system]}</span> ${dur} Min. ${sp.name}, Intensität ${intensity}`;

    // ── Fluid Hint ──
    const fluidEl = document.getElementById('fluidHint');
    const fluidTx = document.getElementById('fluidText');
    if (isShort) {
      fluidTx.textContent = '⏱️ Kurze Einheit unter 10 Minuten — dein Körper braucht keine spezielle Recovery-Mahlzeit. Eine normale ausgewogene Mahlzeit reicht völlig.';
      fluidEl.classList.remove('hidden');
    } else if (isUnrealisticCombo) {
      fluidEl.innerHTML = `⚠️ ${dur} Minuten bei Intensität ${intensity}? Das klingt nach einer gemischten Einheit mit Aufwärmen und Intervallen. <strong style="cursor:pointer;text-decoration:underline;" onclick="document.getElementById('secondToggleBtn').scrollIntoView({behavior:'smooth'});setTimeout(()=>document.getElementById('secondToggleBtn').click(),600)">→ Training aufteilen</strong>`;
      fluidEl.classList.remove('hidden');
    } else if (veryLowIntake) {
      fluidTx.textContent = '⚠️ Du hast heute wenig gegessen und dabei intensiv trainiert. Achte darauf genug zu essen — zu wenig Energie über längere Zeit schadet der Regeneration und Leistungsfähigkeit.';
      fluidEl.classList.remove('hidden');
    } else if (sp.sweat === 'high') {
      fluidTx.textContent = 'Du hast heute viel geschwitzt. Trink jetzt mindestens 500–750 ml Wasser und ergänze Elektrolyte wenn möglich.';
      fluidEl.classList.remove('hidden');
    } else if (sp.sweat === 'none') {
      fluidTx.textContent = 'Beim Schwimmen merkst du das Schwitzen kaum — trink trotzdem 400–500 ml Wasser nach dem Training.';
      fluidEl.classList.remove('hidden');
    } else {
      fluidEl.classList.add('hidden');
    }

    // ── Day Balance ──
    const dinnerVal = document.getElementById('dinner').value;
    const dayOpen   = dinnerVal === 'none';
    const hour      = new Date().getHours();
    const foodMid   = Math.round((foodMin+foodMax)/2);
    const wMid      = Math.round((wMin+wMax)/2);
    const adjMid    = Math.round((adjMin+adjMax)/2);
    const remMid    = Math.max(0, adjMid-foodMid);

    // Always scale against adjMid (Tagesziel) — so bars are relative to goal
    const total = adjMid;
    const pct   = v => Math.min(100, Math.round((v/total)*100));

    // Detect unrealistic spillover — more than 70% of daily goal remaining
    const unrealisticSpillover = remMid > adjMid * 0.7;
    const spilloverColor = unrealisticSpillover ? '#c84b2f' : '#3d7a52';
    const spilloverLabel = unrealisticSpillover ? 'Prüfe deine Eingaben' : 'Noch Spielraum';
    const spilloverSub   = unrealisticSpillover ? 'Spielraum wirkt sehr hoch' : 'kannst du noch essen';

    const rows = [
      {
        label: 'Gegessen',
        sub: 'bisher heute',
        bars: [{ w: pct(foodMid), c: '#3d7a52' }],
        val: foodMid + ' kcal',
        highlight: false
      },
      {
        label: 'Verbrannt',
        sub: 'durch Training',
        bars: [{ w: pct(wMid), c: '#c84b2f' }],
        val: wMid + ' kcal',
        highlight: false
      },
      {
        label: 'Tagesziel',
        sub: 'gegessen + Training + Spielraum',
        bars: [
          { w: pct(foodMid), c: '#3d7a52' },
          { w: pct(wMid * compF), c: '#c84b2f' },
          { w: Math.max(0, Math.min(pct(remMid), 100 - pct(foodMid) - pct(wMid * compF)) - 1), c: '#e2dfd9' }
        ],
        val: adjMid + ' kcal',
        highlight: false
      },
      {
        label: spilloverLabel,
        sub: spilloverSub,
        bars: [{ w: Math.min(100, pct(remMid)), c: spilloverColor }],
        val: status === 'above' ? '–' : '~ ' + remMid + ' kcal',
        highlight: true
      }
    ];

    document.getElementById('dbRows').innerHTML = rows.map(r => `
      <div class="db-row${r.highlight ? ' db-row-highlight' : ''}">
        <div class="db-row-label">${r.label}<span>${r.sub}</span></div>
        <div class="db-track">${r.bars.map(b=>`<div class="db-fill" style="width:${b.w}%;background:${b.c}"></div>`).join('')}</div>
        <div class="db-val${r.highlight ? ' db-val-highlight' : ''}">${r.val}</div>
      </div>`).join('');

    let dbStatusText = '';
    if (unrealisticSpillover) {
      dbStatusText = `<strong>⚠️ Der Spielraum (~${remMid} kcal) wirkt sehr hoch.</strong> Das passiert oft bei gemischten Einheiten — z. B. wenn Aufwärmen und Intervalle zusammen eingegeben werden. Tipp: Nutze die "Zweite Einheit" Funktion und teile das Training auf.`;
    } else if (status==='above') {
      dbStatusText = '<strong>Du liegst heute bereits über deinem Zielbereich.</strong> Setze jetzt auf Protein und etwas Leichtes.';
    } else if (dayOpen && hour < 20) {
      dbStatusText = `<strong>Abendessen fehlt noch.</strong> Du hast noch ca. <strong>${remMid} kcal</strong> Spielraum — plane deine Recovery-Mahlzeit bewusst ein.`;
    } else if (dayOpen && hour >= 20) {
      dbStatusText = `<strong>Abend, Abendessen noch offen.</strong> Noch ca. <strong>${remMid} kcal</strong> Spielraum — jetzt ist der richtige Moment, nicht zu spät und nicht zu schwer.`;
    } else if (status==='low_intake') {
      dbStatusText = `<strong>Noch viel Spielraum heute (~${remMid} kcal).</strong> Iss genug — zu wenig nach dem Training bremst die Regeneration.`;
    } else if (status==='room_left') {
      dbStatusText = `<strong>Ca. ${remMid} kcal Spielraum.</strong> Eine gute Recovery-Mahlzeit passt gut rein.`;
    } else {
      dbStatusText = '<strong>Dein Tag sieht ausgewogen aus.</strong> Eine moderate Mahlzeit rundet ihn gut ab.';
    }
    document.getElementById('dbStatus').innerHTML = dbStatusText;

    // ── Coach Text (sport-specific) ──
    let coach = '';

    if (isUltra) {
      coach = '⚠️ Ultra-Einheit: Bei über 5 Stunden Training gelten andere Regeln. Während des Sports musst du kontinuierlich Kohlenhydrate zuführen — 60–90 g pro Stunde. Danach sofortige Kohlenhydrat- und Proteinzufuhr, viel Flüssigkeit und Elektrolyte. Die Werte hier sind grobe Orientierung — bei solchen Belastungen lohnt sich professionelle Ernährungsberatung. ';
    } else if (isExtreme) {
      coach = '🔥 Lange Einheit: Ab 3 Stunden verändern sich die Prioritäten. Während der Einheit solltest du bereits Kohlenhydrate zugeführt haben. Danach gilt: erst schnelle Kohlenhydrate, dann Protein, viel trinken. ';
    } else if (state.sport === 'cycling' || state.sport === 'mtb') {
      coach = 'Radfahren leert die Glykogenspeicher gleichmäßig und tief — besonders bei langen oder hügeligen Einheiten. ';
      if (dur >= 90) coach += 'Nach über 90 Minuten im Sattel sind Kohlenhydrate genauso wichtig wie Protein. ';
    } else if (state.sport === 'running') {
      coach = 'Laufen beansprucht neben den Energiespeichern auch Muskeln und Bindegewebe stärker als viele andere Sportarten. Protein hilft bei der Reparatur, Kohlenhydrate füllen die Speicher auf. ';
      if (intensity >= 4) coach += 'Nach harten Laufeinheiten lohnt es sich, schnell zu essen — das Regenerationsfenster ist real. ';
    } else if (state.sport === 'swimming') {
      coach = 'Schwimmen ist tückisch: Du merkst das Schwitzen nicht, aber dein Körper arbeitet hart. Viele unterschätzen nach dem Schwimmen ihren Hunger — er kommt oft erst verzögert. ';
    } else if (state.sport === 'rowing') {
      coach = 'Rudern fordert Ober- und Unterkörper gleichzeitig — einer der höchsten Ganzkörper-Energieverbraüche überhaupt. Protein für die Muskeln, Kohlenhydrate für die Speicher, beides zählt. ';
    } else if (state.sport === 'strength' || state.sport === 'climbing') {
      coach = 'Krafttraining und Klettern schädigen Muskelfasern kontrolliert — genau das löst Wachstum aus. Protein ist jetzt der entscheidende Baustein, Kohlenhydrate spielen eine kleinere Rolle. ';
    } else if (state.sport === 'crossfit' || state.sport === 'hiit') {
      coach = sp.name + ' verbrennt in kurzer Zeit viel — und fordert gleichzeitig Muskeln und Ausdauersystem. Du brauchst beides: schnelle Carbs zum Wiederauffüllen und Protein für die Muskeln. ';
    } else if (state.sport === 'football' || state.sport === 'basketball' || state.sport === 'handball') {
      coach = 'Mannschaftssport bedeutet Sprints, Richtungswechsel, Zweikämpfe — explosive Belastungen, die die Glykogenspeicher hart treffen. Nach dem Spiel sind Kohlenhydrate oft wichtiger als man denkt. ';
    } else if (state.sport === 'tennis') {
      coach = 'Tennis kombiniert kurze Maximalsprints mit langen Spielzeiten — das zehrt mehr als es wirkt. Kohlenhydrate und Protein in Kombination helfen am besten. ';
    } else if (state.sport === 'walking') {
      coach = 'Die Belastung war moderat — dein Körper braucht keine große Recovery-Mahlzeit, aber eine leichte eiweißreiche Option tut gut. ';
    } else if (state.sport === 'yoga') {
      coach = 'Yoga beansprucht Muskeln subtiler als du oft merkst — vor allem bei kräftigen Flows oder langen Halteübungen. Eine leichte, proteinreiche Mahlzeit reicht völlig. ';
    } else if (sp.system === 'interval') {
      coach = 'Intervallsport fordert explosive Energie-Systeme. Schnelle Carbs und Protein helfen beim Wiederauffüllen. ';
    } else {
      coach = 'Die Belastung war moderat — dein Körper braucht keine große Recovery-Mahlzeit, aber eine leichte eiweißreiche Option tut gut. ';
    }

    if (intensity<=2) coach += 'Die Intensität war locker, eine leichtere Mahlzeit reicht. ';
    else if (intensity===3) coach += 'Spürbare Einheit. ';
    else coach += 'Fordernde Intensität — gib deinem Körper was er jetzt braucht. ';

    coach += `Orientierung: ${pMin}–${pMax} g Protein, ${cMin}–${cMax} g Kohlenhydrate. `;

    // Carb type recommendation
    let carbType = '', carbFast = '', carbSlow = '', carbTip = '';
    if (intensity >= 4 || dur >= 120) {
      carbType = 'schnell';
      carbFast = 'Banane · Weißreis · Weißbrot · Honig · Sportgetränk · Reiskuchen · Gummibärchen';
      carbSlow = 'Hafer · Vollkornbrot · Süßkartoffel · Linsen · Quinoa';
      carbTip = `Nach intensiven oder langen Einheiten zuerst schnelle Carbs — sie landen in 15–30 Min im Blut und füllen die Glykogenspeicher am schnellsten auf. Langsame Carbs kannst du danach ergänzen.`;
    } else if (intensity >= 3 || dur >= 60) {
      carbType = 'gemischt';
      carbFast = 'Banane · Weißreis · Honig · helles Brot';
      carbSlow = 'Hafer · Vollkornbrot · Kartoffeln · Hülsenfrüchte';
      carbTip = `Ein Mix passt gut: schnelle Carbs starten die Glykogenauffüllung, langsame liefern länger anhaltende Energie und halten den Blutzucker stabil.`;
    } else {
      carbType = 'langsam';
      carbFast = 'Banane · helles Brot · Honig';
      carbSlow = 'Hafer · Vollkornbrot · Kartoffeln · Süßkartoffel · Linsen · Quinoa · Hülsenfrüchte';
      carbTip = `Nach lockeren Einheiten sind langsame Carbs ideal — sie stabilisieren den Blutzucker, machen länger satt und unterstützen die Regeneration ohne Insulinspike.`;
    }
    document.getElementById('rCarbType').innerHTML = `
      <div class="carb-type-label">Empfehlung: <strong>${carbType === 'schnell' ? '⚡ Schnelle Carbs zuerst' : carbType === 'gemischt' ? '⚖️ Schnelle + langsame Carbs' : '🌾 Langsame Carbs'}</strong></div>
      <div class="carb-type-tip">${carbTip}</div>
      <div class="carb-type-row">
        <div class="carb-col">
          <div class="carb-col-label">⚡ Schnell (GI hoch)</div>
          <div class="carb-col-examples">${carbFast}</div>
        </div>
        <div class="carb-col">
          <div class="carb-col-label">🌾 Langsam (GI niedrig)</div>
          <div class="carb-col-examples">${carbSlow}</div>
        </div>
      </div>
    `;
    document.getElementById('rCarbType').classList.remove('hidden');

    if (hour>=21) coach += 'Es ist spät — halte die Mahlzeit leicht und gut verdaulich. ';
    else if (hour>=18&&hour<21) coach += 'Guter Zeitpunkt für eine vollständige Abendmahlzeit. ';
    else if (hour<12) coach += 'Nach dem Morgentraining ist Protein zum Frühstück besonders wichtig. ';

    if (state.goal==='fatloss')  coach += 'Du musst nicht alle Trainingskalorien zurückessen — Protein und Sättigung haben Vorrang.';
    if (state.goal==='build')    coach += 'Dein Ziel ist Aufbau — die Mahlzeit darf energiereicher ausfallen.';
    if (state.goal==='maintain') coach += 'Ausgewogene Regeneration ohne unnötige Überkompensation.';
    document.getElementById('rCoach').textContent = coach;

    // ── Meals with dynamic protein powder ──
    const meals = selectMeals({ sp:state.sport, goal:state.goal, intensity, dur });

    // Dynamic protein powder recommendation
    const shakeProtein = Math.round((pMin + pMax) / 2);
    const shakePowder  = Math.round(shakeProtein * 0.85); // ~85% from powder
    const proteinShake = {
      t: '🥤 Proteinshake — auf dich berechnet',
      b: `Ca. ${shakePowder} g Proteinpulver mit Milch oder Wasser. Mit Milch deutlich proteinreicher und sättigender. Liefert je nach Pulver etwa 28–33 g Protein — ideal wenn du schnell etwas brauchst.`,
      macros: `~${shakeProtein} g Protein · ~10–15 g Carbs (je nach Pulver)`
    };

    document.getElementById('rMeals').innerHTML = [proteinShake, ...meals.slice(0,4)].map(m=>`
      <div class="meal-out"><strong>${m.t}</strong>${m.b}<div class="meal-macros">${m.macros}</div></div>`).join('');

    // ── Share Card — lesbar für Außenstehende ──
    const goalLabels = { fatloss:'Abnehmen', maintain:'Fit bleiben', build:'Aufbau' };
    const pMid = Math.round((pMin+pMax)/2);
    const cMid = Math.round((cMin+cMax)/2);

    const shareMessages = {
      low:   'Eine leichte Recovery-Mahlzeit passt jetzt gut.',
      mid:   'Protein und Carbs auffüllen — der Körper braucht es jetzt.',
      high:  'Intensive Einheit — jetzt gut essen ist wichtig.',
      above: 'Gut versorgt heute — Protein hat jetzt Vorrang.'
    };
    const shareMsg = status==='above' ? shareMessages.above
      : intensity<=2 ? shareMessages.low
      : intensity===3 ? shareMessages.mid
      : shareMessages.high;

    document.getElementById('scTraining').textContent  = `${dur} Min. ${sp.name} · Intensität ${intensity} · ${goalLabels[state.goal]}`;
    document.getElementById('scMacrosRow').textContent = `~${pMid} g Protein · ~${cMid} g Kohlenhydrate`;
    document.getElementById('scKcalRow').textContent   = `Trainingsverbrauch: ${wMin}–${wMax} kcal`;
    document.getElementById('scMsg').textContent       = shareMsg;

    // ── Save to History ──
    saveToHistory({
      ts: Date.now(),
      sport: state.sport,
      sportName: sp.name,
      dur,
      intensity,
      kcal: wMid
    });
    renderHistory();
    renderWeekGraph();

    goTo(4);
  }

  // ── Second Workout ──
  let state2 = { sport: 'strength' };

  setupChips('sportChips2', 'sport', state2);

  function toggleSecondWorkout() {
    const form = document.getElementById('secondForm');
    const btn  = document.getElementById('secondToggleBtn');
    const isHidden = form.classList.contains('hidden');
    form.classList.toggle('hidden', !isHidden);
    btn.textContent = isHidden ? '✕ Schließen' : '➕ Zweite Einheit heute hinzufügen';
  }

  function addSecondWorkout() {
    const dur2 = +document.getElementById('dur2').value;
    const intensity2 = +document.getElementById('intensity2').value;
    if (!dur2) { alert('Bitte Dauer eingeben.'); return; }

    const sp2 = SPORT_PROFILES[state2.sport];
    const w   = +document.getElementById('weight').value;
    const kcal2 = Math.min(sp2.met * w * (dur2/60) * iFactor[intensity2], MAX_KCAL);
    const wMin2 = Math.round(kcal2*.9), wMax2 = Math.round(kcal2*1.1);

    // Extra protein and carbs for second workout
    let pExtra = Math.round(w * pPerKg[intensity2] * sp2.protMod * 0.7); // 70% of full recommendation
    let cExtra = Math.round(w * cPerKg[intensity2] * sp2.carbMod * 0.7);
    pExtra = Math.max(15, pExtra);

    // Remove old second result if exists
    const old = document.getElementById('secondResult');
    if (old) old.remove();

    const div = document.createElement('div');
    div.id = 'secondResult';
    div.className = 'second-result';
    div.innerHTML = `
      <strong>➕ Zweite Einheit: ${sp2.name} ${dur2} Min.</strong>
      Zusätzlicher Verbrauch: ${wMin2}–${wMax2} kcal.<br>
      Mehr Protein: +${pExtra} g · Mehr Kohlenhydrate: +${cExtra} g<br>
      <span style="font-size:12px;opacity:.8;">Dein Körper hat heute doppelt gearbeitet — iss entsprechend mehr, besonders Protein.</span>
    `;
    document.getElementById('secondForm').after(div);

    // Save second workout to history too
    saveToHistory({
      ts: Date.now() + 1,
      sport: state2.sport,
      sportName: sp2.name + ' (2)',
      dur: dur2,
      intensity: intensity2,
      kcal: Math.round(kcal2)
    });
    renderHistory();

    document.getElementById('secondForm').classList.add('hidden');
    document.getElementById('secondToggleBtn').textContent = '✓ Zweite Einheit hinzugefügt';
    document.getElementById('secondToggleBtn').style.borderColor = 'var(--green)';
    document.getElementById('secondToggleBtn').style.color = 'var(--green)';
  }

  // ── Rest Day Calculation ──
  function calculateRestDay(w, h, a, s) {
    const bmrMale   = 10*w+6.25*h-5*a+5;
    const bmrFemale = 10*w+6.25*h-5*a-161;
    const bmr = s==='female' ? bmrFemale : s==='diverse' ? Math.round((bmrMale+bmrFemale)/2) : bmrMale;
    const actF = {sedentary:1.25,normal:1.45,active:1.65}[state.dailyActivity];
    const goalF = {fatloss:.85,maintain:1.0,build:1.05}[state.goal];
    const maint = bmr * actF;
    const target = Math.round(maint * goalF);
    const targetMin = Math.round(target*.95), targetMax = Math.round(target*1.05);

    // Protein for muscle maintenance on rest day — lower than training day
    const pRestDay = Math.max(20, Math.round(w * 0.2));
    const pMin = Math.round(pRestDay*.9), pMax = Math.round(pRestDay*1.1);

    const foodMin = ['breakfast','lunch','dinner','snacks'].reduce((acc,m)=>acc+mealKcal[m][document.getElementById(m).value][0],0);
    const foodMax = ['breakfast','lunch','dinner','snacks'].reduce((acc,m)=>acc+mealKcal[m][document.getElementById(m).value][1],0);
    const foodMid = Math.round((foodMin+foodMax)/2);
    const remMid  = Math.max(0, target - foodMid);

    // Fill metrics
    document.getElementById('rWorkout').textContent = '–';
    document.getElementById('rProtein').textContent = pMin+'–'+pMax+' g';
    document.getElementById('rCarbs').textContent   = '–';
    document.getElementById('resultSub').textContent = '😴 Ruhetag — dein Körper erholt sich. Auch das ist Training.';

    // Hide fluid hint
    document.getElementById('fluidHint').classList.add('hidden');

    // Day balance — simplified for rest day
    const total = Math.max(target, foodMid);
    const pct   = v => Math.min(100, Math.round((v/total)*100));
    document.getElementById('dbRows').innerHTML = [
      { label:'Gegessen', sub:'bisher heute', bars:[{w:pct(foodMid),c:'#3d7a52'}], val:foodMid+' kcal', highlight:false },
      { label:'Tagesbedarf', sub:'Ruhetag', bars:[{w:pct(foodMid),c:'#3d7a52'},{w:Math.max(0,pct(remMid)-1),c:'#e2dfd9'}], val:target+' kcal', highlight:false },
      { label:'Noch Spielraum', sub:'kannst du noch essen', bars:[{w:pct(remMid),c:'#3d7a52'}], val:'~ '+remMid+' kcal', highlight:true }
    ].map(r=>`
      <div class="db-row${r.highlight?' db-row-highlight':''}">
        <div class="db-row-label">${r.label}<span>${r.sub}</span></div>
        <div class="db-track">${r.bars.map(b=>`<div class="db-fill" style="width:${b.w}%;background:${b.c}"></div>`).join('')}</div>
        <div class="db-val${r.highlight?' db-val-highlight':''}">${r.val}</div>
      </div>`).join('');

    const goalLabels = {fatloss:'Abnehmen',maintain:'Fit bleiben',build:'Aufbau'};
    document.getElementById('dbStatus').innerHTML = remMid > 0
      ? `<strong>Noch ca. ${remMid} kcal Spielraum.</strong> Ruhetage sind ideal für eine ausgewogene, leichte Ernährung.`
      : '<strong>Du bist heute gut versorgt.</strong> Perfekt für einen Ruhetag.';

    // Coach text for rest day
    let coach = '😴 Ruhetage sind kein Verlust — sie sind ein Teil des Trainings. ';
    if (state.goal==='fatloss') coach += 'An Ruhetagen ist ein leichtes Kaloriendefizit gut — aber nicht zu stark, sonst leidet die Muskulatur. ';
    if (state.goal==='build')   coach += 'Auch an Ruhetagen braucht der Körper Protein für Muskelreparatur und Wachstum. ';
    if (state.goal==='maintain') coach += 'An Ruhetagen etwas weniger essen als an Trainingstagen ist völlig normal und sinnvoll. ';
    coach += `Protein-Orientierung: ${pMin}–${pMax} g — für Muskelerhalt auch ohne Training wichtig.`;
    document.getElementById('rCoach').textContent = coach;

    // Rest day meals
    const restMeals = [
      { t:'Leichte Gemüsepfanne', b:'Zucchini, Paprika, Brokkoli mit 2–3 Eiern. Viel Volumen, wenig Kalorien, ausreichend Protein.', macros:'~20–26 g Protein · ~15–20 g Carbs' },
      { t:'Joghurt-Bowl', b:'250 g griechischer Joghurt mit Beeren und etwas Granola. Leicht und sättigend.', macros:'~18–25 g Protein · ~25–35 g Carbs' },
      { t:'Linsensuppe', b:'300 ml Linsensuppe mit Vollkornbrot. Pflanzliches Protein, wärmend und sättigend.', macros:'~16–22 g Protein · ~40–50 g Carbs' },
      { t:'Vollkornbrot mit Käse', b:'2–3 Scheiben Vollkornbrot mit 60g Käse, Tomate und Gurke. Einfach und ausgewogen.', macros:'~18–24 g Protein · ~35–45 g Carbs' },
      { t:'Magerquark mit Obst', b:'300 g Magerquark mit Apfel oder Beeren. Protein für Muskelerhalt, leicht verdaulich.', macros:'~30–36 g Protein · ~20–28 g Carbs' }
    ];
    document.getElementById('rMeals').innerHTML = restMeals.map(m=>`
      <div class="meal-out"><strong>${m.t}</strong>${m.b}<div class="meal-macros">${m.macros}</div></div>`).join('');

    // Share card
    document.getElementById('scSport').textContent   = '😴 Ruhetag · Ziel: '+goalLabels[state.goal];
    document.getElementById('scProtein').textContent = pMin+'–'+pMax;
    document.getElementById('scCarbs').textContent   = '–';
    document.getElementById('scKcal').textContent    = target;
    document.getElementById('scMsg').textContent     = 'Ruhe ist auch Training. · afterfuel.de';

    // Hide second workout on rest day
    document.getElementById('secondWrap').classList.add('hidden');

    goTo(4);
  }

  // ── Main Calculation ──
  const HISTORY_KEY = 'afterfuel_history';
  const MAX_HISTORY = 10;

  function loadHistory() {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; }
    catch { return []; }
  }

  function saveToHistory(entry) {
    const history = loadHistory();
    history.unshift(entry);
    if (history.length > MAX_HISTORY) history.length = MAX_HISTORY;
    try { localStorage.setItem(HISTORY_KEY, JSON.stringify(history)); } catch {}
  }

  function clearHistory() {
    try { localStorage.removeItem(HISTORY_KEY); }
    catch {}
    document.getElementById('historyWrap').classList.add('hidden');
    document.getElementById('weekGraphWrap').classList.add('hidden');
  }

  function renderWeekGraph() {
    const history = loadHistory();
    const wrap    = document.getElementById('weekGraphWrap');
    if (history.length < 1) { wrap.classList.add('hidden'); return; }

    const intensityColors = {
      0: null, 1: '#f5ede6', 2: '#f2c4a8', 3: '#e8956d', 4: '#c84b2f', 5: '#2d5a3d'
    };
    const intensityNames = {
      0: 'kein Training', 1: 'sehr leicht', 2: 'leicht', 3: 'moderat', 4: 'hart', 5: 'sehr hart'
    };

    const days = ['Mo','Di','Mi','Do','Fr','Sa','So'];
    const today = new Date();
    const buckets = Array.from({length:7}, (_,i) => {
      const d = new Date(today);
      d.setDate(today.getDate() - (6-i));
      const dayIdx = d.getDay()===0 ? 6 : d.getDay()-1;
      return { label: days[dayIdx], date: d, intensity: 0, kcal: 0, sport: null, isToday: d.toDateString()===today.toDateString() };
    });

    history.forEach(h => {
      const hDate = new Date(h.ts);
      buckets.forEach(b => {
        if (hDate.toDateString() === b.date.toDateString()) {
          if (h.intensity > b.intensity) { b.intensity = h.intensity; b.sport = h.sportName; }
          b.kcal += (h.kcal || 0);
        }
      });
    });

    const intenseDays = buckets.filter(b => b.intensity >= 4).length;
    const easyDays    = buckets.filter(b => b.intensity >= 1 && b.intensity <= 3).length;
    const restDays    = buckets.filter(b => b.intensity === 0).length;
    const activeDays  = intenseDays + easyDays;

    let summaryLine = '';
    if (activeDays === 0) summaryLine = 'Diese Woche noch keine Einheiten erfasst.';
    else if (intenseDays === 0) summaryLine = `Du hattest <span class="easy">${easyDays} lockere Einheit${easyDays===1?'':'en'}</span> diese Woche.`;
    else if (easyDays === 0) summaryLine = `Du hattest <span class="intense">${intenseDays} intensive${intenseDays===1?' Tag':' Tage'}</span> diese Woche.`;
    else summaryLine = `Du hattest <span class="intense">${intenseDays} intensive${intenseDays===1?' Tag':' Tage'}</span> und <span class="easy">${easyDays} lockere${easyDays===1?' Tag':' Tage'}</span>.`;

    let balanceLine = '';
    if (activeDays === 0) balanceLine = history.length > 0 ? `Letzte Einheit: ${new Date(history[0].ts).toLocaleDateString('de-DE',{weekday:'short',day:'numeric',month:'short'})}.` : '';
    else if (restDays === 0) balanceLine = 'Denk auch mal an einen Ruhetag.';
    else if (intenseDays >= 4) balanceLine = 'Viel Einsatz diese Woche.';
    else if (activeDays <= 2) balanceLine = 'Ruhige Woche — manchmal genau richtig.';
    else balanceLine = 'Gute Balance.';

    document.getElementById('weekSummary').innerHTML = `
      <div class="week-summary-title">Deine Woche</div>
      <div class="week-summary-sub">${summaryLine}${balanceLine ? '<br>'+balanceLine : ''}</div>`;

    const maxH = 100;
    const chartHTML = buckets.map(b => {
      const barH  = b.intensity > 0 ? Math.round((b.intensity/5)*maxH) : 0;
      const color = intensityColors[b.intensity];
      return `<div class="week-bar-wrap">
        ${b.intensity > 0
          ? `<div style="flex:1;display:flex;align-items:flex-end;width:100%;height:100%;"><div class="week-bar" style="height:${barH}px;background:${color};" title="${intensityNames[b.intensity]}${b.sport?' · '+b.sport:''}${b.kcal?' · '+b.kcal+' kcal':''}"></div></div>`
          : `<div style="flex:1;display:flex;align-items:flex-end;justify-content:center;width:100%;height:100%;"><div class="week-bar-rest"></div></div>`}
        <div class="week-day-label${b.isToday?' today':''}">${b.label}</div>
      </div>`;
    }).join('');
    document.getElementById('weekGraph').innerHTML = chartHTML;

    const lastEntry = history[0];
    if (lastEntry) {
      const lastDate   = new Date(lastEntry.ts);
      const lastDay    = days[lastDate.getDay()===0?6:lastDate.getDay()-1];
      const lastIntens = intensityNames[lastEntry.intensity] || '';
      const todayBucket = buckets[6];
      const todayText  = todayBucket.intensity > 0
        ? `${intensityNames[todayBucket.intensity]} · ${todayBucket.sport||''}`
        : 'Ruhetag';
      document.getElementById('weekFooter').innerHTML = `
        <div class="week-footer-item">
          <div class="week-footer-icon">🏅</div>
          <div><div class="week-footer-label">Letzte Einheit</div>
          <div class="week-footer-value">${lastDay} – ${lastIntens}</div></div>
        </div>
        <div class="week-footer-item">
          <div class="week-footer-icon">${todayBucket.intensity>0?'⚡':'☕'}</div>
          <div><div class="week-footer-label">Heute</div>
          <div class="week-footer-value" style="color:${todayBucket.intensity>0?'var(--accent)':'var(--green)'}">${todayText}</div></div>
        </div>`;
    }
    wrap.classList.remove('hidden');
  }

  function renderHistory() {
    const history = loadHistory();
    const wrap = document.getElementById('historyWrap');
    if (history.length < 2) { wrap.classList.add('hidden'); return; }

    const recent = history.slice(0, 7);
    const maxKcal = Math.max(...recent.map(h => h.kcal));
    const sportEmoji = {
      cycling:'🚴', mtb:'🚵', running:'🏃', swimming:'🏊', rowing:'🚣',
      walking:'🚶', strength:'🏋️', climbing:'🧗', crossfit:'💪', hiit:'⚡',
      football:'⚽', basketball:'🏀', handball:'🤾', tennis:'🎾', yoga:'🧘'
    };

    document.getElementById('historyChart').innerHTML = recent.map(h => {
      const barW = Math.round((h.kcal / maxKcal) * 100);
      const date = new Date(h.ts);
      const dateStr = date.toLocaleDateString('de-DE', { weekday:'short', day:'numeric', month:'short' });
      return `
        <div class="history-row">
          <div class="history-meta">
            <div class="history-date">${dateStr}</div>
            <div class="history-sport">${sportEmoji[h.sport] || '🏅'} ${h.sportName} ${h.dur} Min.</div>
          </div>
          <div class="history-bar-wrap">
            <div class="history-bar" style="width:${barW}%"></div>
          </div>
          <div class="history-kcal">${h.kcal} kcal</div>
        </div>`;
    }).join('');

    wrap.classList.remove('hidden');
  }

  // ── Share as Image ──
  async function shareAsImage() {
    const card = document.getElementById('shareCard');
    try {
      const canvas = await html2canvas(card, {
        backgroundColor: '#1c1a17',
        scale: 2,
        useCORS: true,
        logging: false
      });
      canvas.toBlob(async blob => {
        if (!blob) return;
        const file = new File([blob], 'afterfuel.png', { type:'image/png' });
        if (navigator.canShare && navigator.canShare({ files:[file] })) {
          await navigator.share({ files:[file], title:'AfterFuel – meine Empfehlung nach dem Training', url:'https://afterfuel.de' });
        } else {
          // Fallback: download
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = 'afterfuel.png'; a.click();
          URL.revokeObjectURL(url);
        }
      }, 'image/png');
    } catch(e) {
      alert('Bild konnte nicht erstellt werden. Versuche "Text kopieren".');
    }
  }

  function getShareText() {
    const r=lastResult, g={fatloss:'Abnehmen',maintain:'Fit bleiben',build:'Aufbau'};
    const pMid = Math.round((r.pMin+r.pMax)/2);
    const cMid = Math.round((r.cMin+r.cMax)/2);
    return `🔥 AfterFuel — Post-Workout Empfehlung\n\n🏅 ${r.dur} Min. ${r.sportName} · Intensität ${r.intensity} · ${g[r.goal]}\n\nPost-Workout Ziel:\n~${pMid} g Protein · ~${cMid} g Kohlenhydrate\nTrainingsverbrauch: ${r.wMin}–${r.wMax} kcal\n\nKein Tracking nötig → afterfuel.de`;
  }

  function copyShareText() {
    navigator.clipboard.writeText(getShareText()).then(()=>alert('Text kopiert! 📋')).catch(()=>alert('Kopieren nicht möglich.'));
  }

  function shareNative() {
    if (navigator.share) { navigator.share({title:'AfterFuel',text:getShareText(),url:'https://afterfuel.de'}).catch(()=>{}); }
    else copyShareText();
  }

  // ── Service Worker Registration ──
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    });
  }

  function togglePreFuelTool(force) {
    const panel = document.getElementById('preFuelToolPanel');
    if (!panel) return;

    const panels = ['cyclingToolPanel','runningToolPanel','strengthToolPanel','sessionDecoderToolPanel','duringFuelToolPanel','heatSweatToolPanel','recoveryCheckToolPanel'];
    panels.forEach(id => document.getElementById(id)?.classList.add('hidden'));

    const shouldShow = typeof force === 'boolean' ? force : panel.classList.contains('hidden');
    panel.classList.toggle('hidden', !shouldShow);
    if (shouldShow) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function calculatePreFuelTool() {
    const sport = document.getElementById('pfSport').value;
    const timing = document.getElementById('pfTiming').value;
    const dur = +(document.getElementById('pfDuration').value || 0);
    const intensity = +(document.getElementById('pfIntensity').value || 2);
    const weight = +(document.getElementById('pfWeight').value || 0);
    const age = +(document.getElementById('pfAge').value || 0);

    if (!dur || dur < 1) { alert('Bitte eine Dauer eingeben.'); return; }

    const isHard = intensity >= 4;
    const isLong = dur >= 90;
    const isVeryLong = dur >= 150;
    const hasWeight = weight >= 30;
    const isOlderAthlete = age >= 45;

    // Carb targets per kg bodyweight based on timing + intensity
    // Basis: 0.5–1.0 g/kg für moderate, 1.0–1.5 g/kg für intensive Einheiten
    let carbsLow = 0, carbsHigh = 0, carbsText = '', timingText = '', ideas = '', interpretation = '';

    if (timing === 'soon') {
      timingText = 'sehr leicht / nur Snack';
      carbsLow = isHard || isLong ? 0.3 : 0.1;
      carbsHigh = isHard || isLong ? 0.5 : 0.3;
      ideas = isHard || isLong ? 'Banane · Carb-Würfel · Gel · Reiskuchen' : 'Banane · kleiner Joghurt · Wasser';
      interpretation = 'Kurz vor dem Training zählt Verträglichkeit vor allem anderen. Große, fettige oder ballaststoffreiche Mahlzeiten jetzt eher vermeiden.';
    } else if (timing === 'medium') {
      timingText = 'kleiner bis mittlerer Snack';
      carbsLow = isHard || isLong ? 0.5 : 0.3;
      carbsHigh = isHard || isLong ? 1.0 : 0.6;
      ideas = isHard || isLong ? 'Banane + Toast · Reiskuchen + Honig · Fruchtriegel' : 'Banane · Joghurt mit Obst · kleines Brot';
      interpretation = '30–90 Minuten vorher funktionieren leicht verdauliche Kohlenhydrate gut, besonders bei intensiven Einheiten.';
    } else if (timing === 'later') {
      timingText = 'leichte Mahlzeit';
      carbsLow = isHard || isLong ? 1.0 : 0.7;
      carbsHigh = isHard || isLong ? 2.0 : 1.2;
      ideas = 'Haferflocken mit Banane · Brot mit Ei · Reisgericht leicht gehalten · Joghurt mit Obst';
      interpretation = 'Bei 1,5–3 Stunden Abstand darf die Mahlzeit größer sein. Je intensiver die Einheit, desto mehr verträgliche Kohlenhydrate sind sinnvoll.';
    } else {
      timingText = 'normal essen';
      carbsLow = 0; carbsHigh = 0;
      ideas = 'normale Mahlzeit · ausreichend trinken · kurz vor Start kleinen Snack nach Gefühl';
      interpretation = 'Wenn das Training erst viel später ist, zählt die Tagesstruktur mehr als Timing. Kurz vor dem Start kannst du leicht nachlegen.';
    }

    // Strength: shift focus to protein
    if (sport === 'strength') {
      if (isHard) {
        carbsLow = Math.max(carbsLow * 0.7, 0.3);
        carbsHigh = Math.max(carbsHigh * 0.7, 0.6);
        ideas = timing === 'soon' ? 'kleiner Shake · Banane · Joghurt' : 'Quark/Joghurt mit Obst · Brot mit Ei · Shake + Banane';
        interpretation += ' Krafttraining: weniger Carb-Menge, dafür Protein mitdenken.';
      } else {
        carbsLow = 0; carbsHigh = 0;
        ideas = 'normale Mahlzeit · Joghurt · Quark · nach Gefühl';
        interpretation += ' Für lockeres Krafttraining reicht normales Essen meist gut.';
      }
    }

    if (isVeryLong && (sport === 'cycling' || sport === 'running')) {
      interpretation += ' Bei sehr langen Einheiten: nicht nur PreFuel, sondern auch Fueling während der Einheit einplanen.';
    }

    // Older athlete note
    if (isOlderAthlete) {
      interpretation += ' Ab 45+ lohnt es sich, Protein über den ganzen Tag gut zu verteilen — auch die Mahlzeit vor dem Training kann etwas Protein enthalten.';
    }

    // Build carbs display
    if (carbsLow === 0 && carbsHigh === 0) {
      carbsText = 'kein spezielles PreFuel nötig';
    } else if (hasWeight) {
      const lo = Math.round(carbsLow * weight / 5) * 5;
      const hi = Math.round(carbsHigh * weight / 5) * 5;
      carbsText = `${lo}–${hi} g Kohlenhydrate`;
    } else {
      carbsText = `${carbsLow.toFixed(1)}–${carbsHigh.toFixed(1)} g/kg Körpergewicht`;
    }

    // Protein for strength
    let proteinRow = '';
    if (sport === 'strength' && isHard && hasWeight) {
      const protLo = Math.round(weight * 0.2);
      const protHi = Math.round(weight * 0.3);
      proteinRow = `<div class="tool-result"><div class="tool-result-label">Protein</div><div class="tool-result-value">${protLo}–${protHi} g</div><div class="tool-result-sub">vor intensivem Krafttraining</div></div>`;
    }

    // Carb type for PreFuel depends on timing
    let pfCarbTypeHTML = '';
    if (carbsLow > 0 || carbsHigh > 0) {
      let pfFast = '', pfSlow = '', pfTypeLabel = '', pfTypeTip = '';
      if (timing === 'soon') {
        pfTypeLabel = '⚡ Nur schnelle Carbs';
        pfFast = 'Banane · Gel · Gummibärchen · Reiskuchen · Sportgetränk';
        pfSlow = '— jetzt nicht empfehlenswert';
        pfTypeTip = 'Kurz vor dem Training nur schnelle Carbs — kein Fett, keine Ballaststoffe, nichts Schweres.';
      } else if (timing === 'medium') {
        pfTypeLabel = '⚡ Schnelle Carbs, leicht';
        pfFast = 'Banane · Toast mit Honig · Reiskuchen · helles Brötchen';
        pfSlow = 'Hafer mit Banane (wenn > 60 Min noch Zeit)';
        pfTypeTip = '30–90 Min vorher: leicht verdauliche, schnelle Carbs. Nichts Fettiges oder Ballaststoffreiches.';
      } else if (timing === 'later') {
        pfTypeLabel = '⚖️ Gemischt — langsam + schnell';
        pfFast = 'Banane · Weißreis · helles Brot · Honig';
        pfSlow = 'Haferflocken · Vollkornbrot · Süßkartoffel · Quinoa';
        pfTypeTip = '1,5–3 Stunden vorher passt ein Mix gut: langsame Carbs für stabile Energie, kleine schnelle Carbs kurz vor dem Start.';
      } else {
        pfTypeLabel = '🌾 Langsame Carbs — normale Mahlzeit';
        pfFast = 'Banane · Honig (kurz vor Start)';
        pfSlow = 'Haferflocken · Vollkornbrot · Kartoffeln · Hülsenfrüchte · Quinoa · Süßkartoffel';
        pfTypeTip = 'Bei viel Zeit zählt die gesamte Tagesernährung mehr als Timing. Langsame Carbs halten Energie und Blutzucker stabil.';
      }
      pfCarbTypeHTML = `
        <div class="carb-type-box" style="margin-top:12px;">
          <div class="carb-type-label"><strong>${pfTypeLabel}</strong></div>
          <div class="carb-type-tip">${pfTypeTip}</div>
          <div class="carb-type-row">
            <div class="carb-col"><div class="carb-col-label">⚡ Schnell</div><div class="carb-col-examples">${pfFast}</div></div>
            <div class="carb-col"><div class="carb-col-label">🌾 Langsam</div><div class="carb-col-examples">${pfSlow}</div></div>
          </div>
        </div>`;
    }

    document.getElementById('pfResults').innerHTML = `
      <div class="tool-result"><div class="tool-result-label">Timing</div><div class="tool-result-value">${timingText}</div><div class="tool-result-sub">vor dem Start</div></div>
      <div class="tool-result"><div class="tool-result-label">Kohlenhydrate</div><div class="tool-result-value">${carbsText}</div><div class="tool-result-sub">${hasWeight ? 'für ' + weight + ' kg' : 'ohne Gewicht — Richtwert'}</div></div>
      ${proteinRow}
      <div class="tool-result"><div class="tool-result-label">Ideen</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;line-height:1.35;">${ideas}</div><div class="tool-result-sub">leicht verträglich</div></div>
    ` + pfCarbTypeHTML;
    document.getElementById('pfResults').classList.remove('hidden');
    document.getElementById('pfInterpretation').innerHTML = `<strong>Einordnung</strong><br>${interpretation}`;
    document.getElementById('pfInterpretation').classList.remove('hidden');
    document.getElementById('pfDisclaimer').classList.remove('hidden');
    document.getElementById('pfScience').classList.remove('hidden');
  }



  function hidePerformancePanels(exceptId) {
    ['cyclingToolPanel','runningToolPanel','strengthToolPanel','preFuelToolPanel','sessionDecoderToolPanel','duringFuelToolPanel','heatSweatToolPanel','recoveryCheckToolPanel']
      .forEach(id => { if (id !== exceptId) document.getElementById(id)?.classList.add('hidden'); });
  }

  function toggleSessionDecoderTool(force) {
    const panel = document.getElementById('sessionDecoderToolPanel');
    if (!panel) return;
    hidePerformancePanels('sessionDecoderToolPanel');
    const show = typeof force === 'boolean' ? force : panel.classList.contains('hidden');
    panel.classList.toggle('hidden', !show);
    if (show) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

