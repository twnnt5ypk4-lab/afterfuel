  <script>
  function getCyclingPlausibility(distanceKm, durationMin, avgPower, ftpInput) {
    const warnings = [];
    const speed = durationMin > 0 && distanceKm > 0 ? distanceKm / (durationMin / 60) : null;

    if (speed !== null) {
      if (speed < 8 && avgPower > 180) warnings.push('Die Leistung wirkt für die angegebene Distanz/Zeit sehr hoch. Prüfe Pausen, Indoor-Fahrt oder falsche Distanz.');
      if (speed > 45 && avgPower < 140) warnings.push('Die Geschwindigkeit wirkt für die angegebene Leistung sehr hoch. Windschatten, Gefälle, E-Bike, Rollenfahrt oder falsche Leistung können die Ursache sein.');
      if (speed > 60) warnings.push('Die Durchschnittsgeschwindigkeit ist ungewöhnlich hoch. Bitte Distanz und Dauer prüfen.');
    }

    if (ftpInput && avgPower) {
      const ratio = avgPower / ftpInput;
      if (durationMin >= 60 && ratio > 1.05) warnings.push('Ø-Leistung liegt über FTP bei mindestens 60 Minuten. Das kann ein sehr harter Test sein – oder FTP ist zu niedrig / Leistung falsch.');
      if (durationMin >= 20 && ratio > 1.25) warnings.push('Ø-Leistung liegt deutlich über FTP. Prüfe, ob FTP aktuell ist oder ob die Leistung ein kurzer Peak/Normalised Power statt Ø-Leistung ist.');
      if (durationMin >= 90 && ratio > 0.95) warnings.push('Sehr hohe Intensität für eine lange Einheit. Möglich, aber ungewöhnlich – FTP oder Dauer prüfen.');
    }

    return warnings;
  }

  function updateCyclingMethodVisibility(confidenceText, warnings) {
    const note = document.getElementById('cyclingMethodNote');
    const pill = document.getElementById('cyclingConfidencePill');
    const warningBox = document.getElementById('cyclingPlausibilityWarning');

    if (note) note.classList.remove('hidden');
    if (pill && confidenceText) pill.textContent = confidenceText;

    if (warningBox) {
      if (warnings && warnings.length) {
        warningBox.innerHTML = '<strong>Plausibilitätscheck</strong>' + warnings.join('<br>');
        warningBox.classList.remove('hidden');
      } else {
        warningBox.classList.add('hidden');
        warningBox.innerHTML = '';
      }
    }
  }


  function getCyclingInterpretation(ftp, vo2, wkg) {
    let text = '';

    if (ftp >= 300 || vo2 >= 55 || wkg >= 4.2) {
      text = 'Sehr starke Ausdauerbasis. Die Werte liegen klar über typischen Hobbybereich.';
    } else if (ftp >= 240 || vo2 >= 45 || wkg >= 3.2) {
      text = 'Solide bis gute Ausdauerbasis mit strukturiertem Trainingsniveau.';
    } else if (ftp >= 180 || vo2 >= 35 || wkg >= 2.2) {
      text = 'Gute Grundlage für Gesundheit, Fitness und weitere Leistungsentwicklung.';
    } else {
      text = 'Frühe Trainingsbasis. Regelmäßigkeit bringt hier oft schnelle Fortschritte.';
    }

    return text;
  }

  function updateCyclingInterpretation() {
    const box = document.getElementById('cyclingInterpretation');
    if (!box) return;

    const ftp =
      +(document.getElementById('cyclingFtp')?.value ||
      document.getElementById('ftpInput')?.value || 0);

    const vo2Text =
      document.getElementById('cyclingVo2')?.textContent ||
      document.getElementById('vo2Result')?.textContent || '';

    const wkgText =
      document.getElementById('cyclingWkg')?.textContent ||
      document.getElementById('wkgResult')?.textContent || '';

    const vo2 = parseFloat(vo2Text.replace(',', '.')) || 0;
    const wkg = parseFloat(wkgText.replace(',', '.')) || 0;

    box.innerHTML =
      '<strong>Einordnung</strong><br>' +
      getCyclingInterpretation(ftp, vo2, wkg) +
      '<br><br><strong>Fuel-Hinweis:</strong><br>' +
      'Höhere Intensitäten und lange Einheiten erhöhen den Kohlenhydratbedarf deutlich. ' +
      'Leichte Zone-2-Einheiten benötigen meist weniger aggressive Recovery-Fuels.';

    box.classList.remove('hidden');
  }

</script>

