        <!-- Mode: Wettkampfzeit -->
        <div id="rtPanelRace">
          <div class="form-row">
            <div class="field">
              <label class="field-label" for="rtWeight">Gewicht (kg)</label>
              <input type="number" id="rtWeight" placeholder="z. B. 75" min="30" max="250" oninput="runningCalcLive()" />
            </div>
            <div class="field">
              <label class="field-label" for="rtDist">Wettkampfdistanz</label>
              <select id="rtDist" onchange="runningCalcLive()">
                <option value="1500">1.500 m</option>
                <option value="3000">3.000 m</option>
                <option value="5000" selected>5 km</option>
                <option value="10000">10 km</option>
                <option value="21097">Halbmarathon</option>
                <option value="42195">Marathon</option>
              </select>
            </div>
