  // ── Field Validation ──
  const errorMessages = {
    weight: { low: 'Das ist etwas wenig 😄 — bitte 30–250 kg eingeben.', high: 'Das ist etwas viel 😄 — bitte 30–250 kg eingeben.' },
    height: { low: 'Das ist etwas klein 😄 — bitte 120–230 cm eingeben.', high: 'Das ist etwas groß 😄 — bitte 120–230 cm eingeben.' },
    age:    { low: 'AfterFuel ist ab 16 Jahren — bitte ein gültiges Alter eingeben.', high: 'Das ist ein sehr gesundes Alter 😄 — bitte 16–90 Jahre eingeben.' },
    durationMinutes: { low: 'Bitte mindestens 1 Minute eingeben.', high: 'Das wären über 10 Stunden — bitte 1–600 Minuten eingeben 😄.' }
  };

  function validateField(id, min, max) {
    const input = document.getElementById(id);
    const error = document.getElementById(id + '-error');
    const val   = +input.value;
    if (!input.value) { input.classList.remove('invalid'); error.classList.add('hidden'); return true; }
    if (val < min) {
      input.classList.add('invalid');
      error.textContent = errorMessages[id]?.low || `Bitte ${min}–${max} eingeben.`;
      error.classList.remove('hidden');
      return false;
    }
    if (val > max) {
      input.classList.add('invalid');
      error.textContent = errorMessages[id]?.high || `Bitte ${min}–${max} eingeben.`;
      error.classList.remove('hidden');
      return false;
    }
    input.classList.remove('invalid');
    error.classList.add('hidden');
    return true;
  }

  function validateAll() {
    const checks = [
      validateField('weight', 30, 250),
      validateField('height', 120, 230),
      validateField('age', 16, 90)
    ];
    return checks.every(Boolean);
  }

