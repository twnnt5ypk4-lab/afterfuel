<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
  function toggleScience(btn) {
    btn.classList.toggle('open');
    const content = btn.nextElementSibling;
    content.classList.toggle('open');
  }

  const state = { goal:'fatloss', dailyActivity:'normal', sport:'cycling' };
  let lastResult = {};

  // ── User Data Persistence ──
  const USER_KEY = 'afterfuel_user';

  function saveUserData() {
    const data = {
      weight: document.getElementById('weight').value,
      height: document.getElementById('height').value,
      age:    document.getElementById('age').value,
      sex:    document.getElementById('sex').value,
      goal:   state.goal,
      dailyActivity: state.dailyActivity
    };
    try { localStorage.setItem(USER_KEY, JSON.stringify(data)); } catch {}
  }

  function loadUserData() {
    try {
      const data = JSON.parse(localStorage.getItem(USER_KEY));
      if (!data) return;
      if (data.weight) document.getElementById('weight').value = data.weight;
      if (data.height) document.getElementById('height').value = data.height;
      if (data.age)    document.getElementById('age').value    = data.age;
      if (data.sex)    document.getElementById('sex').value    = data.sex;
      if (data.goal) {
        state.goal = data.goal;
        document.querySelectorAll('#goalChips .chip').forEach(c => c.classList.toggle('selected', c.dataset.val === data.goal));
      }
      if (data.dailyActivity) {
        state.dailyActivity = data.dailyActivity;
        document.querySelectorAll('#activityChips .chip').forEach(c => c.classList.toggle('selected', c.dataset.val === data.dailyActivity));
      }
    } catch {}
  }

  // Load on start
