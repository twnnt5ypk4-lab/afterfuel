  function calculateSessionDecoder() {
    const sport = document.getElementById('sdSport').value;
    const dur = +(document.getElementById('sdDuration').value || 0);
    const intensity = +(document.getElementById('sdIntensity').value || 2);
    const feeling = document.getElementById('sdFeeling').value;
    if (!dur) { alert('Bitte eine Dauer eingeben.'); return; }

    const isLong = dur >= 90, isVeryLong = dur >= 150, isHard = intensity >= 4;
    let primary = 'aerobe Grundlage', fuel = 'moderat', recovery = 'leicht bis mittel';
    let text = 'Das war eine normale Trainingseinheit. Eine ausgewogene Mahlzeit und ausreichend Flüssigkeit passen gut.';

    if (sport === 'strength') {
      primary = isHard ? 'muskulärer Reiz' : 'Kraft-/Technikreiz';
      fuel = isHard ? 'Protein priorisieren' : 'moderat';
      recovery = isHard ? 'mittel bis hoch' : 'leicht bis mittel';
      text = isHard ? 'Die Einheit war wahrscheinlich stärker muskulär als metabolisch belastend. Protein, Schlaf und normale Kohlenhydrate sind wichtiger als ein riesiger Zucker-Refill.' : 'Das war eher ein kontrollierter Kraftreiz. Eine normale eiweißreiche Mahlzeit reicht meist gut aus.';
    } else if (sport === 'mixed') {
      primary = 'glycogen- und neuromuskulär';
      fuel = isHard ? 'hoch' : 'mittel';
      recovery = isHard ? 'mittel bis hoch' : 'mittel';
      text = 'Intervall- und Mixed-Einheiten fordern oft mehrere Systeme gleichzeitig: schnelle Energie, Koordination und lokale Muskulatur.';
    } else if (sport === 'cycling' || sport === 'running') {
      if (isVeryLong) {
        primary = 'lange Speicherbelastung';
        fuel = 'hoch';
        recovery = 'hoch';
        text = 'Das war wahrscheinlich eine deutliche Ausdauer- und Speicherbelastung. Kohlenhydrate, Flüssigkeit und Elektrolyte werden wichtiger.';
      } else if (isHard) {
        primary = 'intensiver Glycogenreiz';
        fuel = 'mittel bis hoch';
        recovery = 'mittel bis hoch';
        text = 'Die Einheit war wahrscheinlich glycogen-lastig. Genau hier machen kleine Pre- und During-Fuel-Strategien oft einen spürbaren Unterschied.';
      } else if (isLong) {
        primary = 'aerobe Ausdauer';
        fuel = 'mittel';
        recovery = 'mittel';
        text = 'Das war wahrscheinlich eine solide aerobe Belastung. Nicht maximal hart, aber lang genug, dass Essen und Flüssigkeit danach relevant werden.';
      }
    } else {
      primary = 'Bewegung & Erholung';
      fuel = 'niedrig';
      recovery = 'leicht';
      text = 'Das war wahrscheinlich eher regenerativ. Gut für Bewegung, Kreislauf und Alltag — ohne großen speziellen Fuel-Bedarf.';
    }

    if (feeling === 'empty') {
      text += ' Das leere Gefühl spricht zusätzlich dafür, heute nicht zu knapp zu essen und vor der nächsten harten Einheit besser zu fueln.';
      if (recovery === 'leicht') recovery = 'mittel';
    } else if (feeling === 'sore') {
      text += ' Das muskulär schwere Gefühl spricht für lokalen Reparaturbedarf: Protein, Ruhe und ein nicht zu hartes Folgetraining sind sinnvoll.';
      recovery = recovery.includes('hoch') ? recovery : 'mittel bis hoch';
    } else if (feeling === 'fresh') {
      text += ' Dass du dich stabil fühlst, ist ein gutes Zeichen — wahrscheinlich war die Belastung gut dosiert.';
    }

    document.getElementById('sdResults').innerHTML = `
      <div class="tool-result"><div class="tool-result-label">Hauptreiz</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;line-height:1.35;">${primary}</div><div class="tool-result-sub">wahrscheinliche Belastung</div></div>
      <div class="tool-result"><div class="tool-result-label">Fuel-Bedarf</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;line-height:1.35;">${fuel}</div><div class="tool-result-sub">Carbs / Protein</div></div>
      <div class="tool-result"><div class="tool-result-label">Recovery</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;line-height:1.35;">${recovery}</div><div class="tool-result-sub">Rest des Tages</div></div>`;
    document.getElementById('sdResults').classList.remove('hidden');
    document.getElementById('sdInterpretation').innerHTML = `<strong>Einordnung</strong><br>${text}`;
    document.getElementById('sdInterpretation').classList.remove('hidden');
    document.getElementById('sdDisclaimer').classList.remove('hidden');
    document.getElementById('sdScience').classList.remove('hidden');
  }

  function calculateDuringFuel() {
    const sport = document.getElementById('dfSport').value;
    const dur = +(document.getElementById('dfDuration').value || 0);
    const intensity = +(document.getElementById('dfIntensity').value || 2);
    const heat = document.getElementById('dfHeat').value;
    const weight = +(document.getElementById('dfWeight').value || 0);
    const age = +(document.getElementById('dfAge').value || 0);
    if (!dur) { alert('Bitte eine Dauer eingeben.'); return; }

    const hasWeight = weight >= 30;
    const isOlderAthlete = age >= 45;
    const hours = dur / 60;

    // Carb targets in g/h — basis ohne Gewicht
    let carbLow = 0, carbHigh = 0;
    // Fluid: base rate in ml/h
    let fluidLow = 300, fluidHigh = 500;
    let electrolytes = 'meist nicht nötig';
    let text = '';

    if (dur >= 150 || intensity >= 5) {
      carbLow = sport === 'running' ? 40 : 60;
      carbHigh = sport === 'running' ? 70 : 90;
      fluidLow = 500; fluidHigh = 900;
      electrolytes = 'sinnvoll';
      text = 'Bei langen oder sehr intensiven Einheiten wird Fueling währenddessen leistungsrelevant. Früh und gleichmäßig starten — nicht warten bis du leer bist.';
    } else if (dur >= 90 || intensity >= 4) {
      carbLow = sport === 'running' ? 30 : 40;
      carbHigh = sport === 'running' ? 60 : 70;
      fluidLow = 450; fluidHigh = 750;
      electrolytes = (heat === 'warm' || heat === 'indoor') ? 'sinnvoll' : 'optional';
      text = 'Ab etwa 90 Minuten oder bei hoher Intensität machen regelmäßige Kohlenhydrate die Einheit deutlich stabiler.';
    } else if (dur >= 60 && intensity >= 3) {
      carbLow = 20; carbHigh = 40;
      fluidLow = 350; fluidHigh = 600;
      electrolytes = (heat === 'warm' || heat === 'indoor') ? 'optional bis sinnvoll' : 'optional';
      text = 'Bei moderaten Einheiten um eine Stunde reichen kleine Mengen. Wichtig: nicht völlig leer starten.';
    } else {
      carbLow = 0; carbHigh = 20;
      text = 'Bei kurzen oder lockeren Einheiten reicht normales Trinken. Carbs währenddessen sind optional.';
    }

    // Heat modifier for fluid
    if (heat === 'warm') { fluidLow += 100; fluidHigh += 200; text += ' Wärme erhöht den Flüssigkeitsbedarf spürbar.'; }
    if (heat === 'indoor') { fluidLow += 150; fluidHigh += 300; text += ' Indoor-Training: Schweißverlust wird oft unterschätzt weil der Fahrtwind fehlt.'; }

    // Weight-adjusted carbs per hour
    let carbsDisplay = '';
    if (carbLow === 0 && carbHigh <= 20) {
      carbsDisplay = hasWeight ? `0–${Math.round(0.25 * weight)} g/h` : '0–20 g/h';
    } else if (hasWeight) {
      // Scientific basis: 0.5–1.2 g/kg/h for endurance, capped at gut limit
      const wLo = Math.min(Math.round(carbLow * (weight / 70) / 5) * 5, carbLow + 10);
      const wHi = Math.min(Math.round(carbHigh * (weight / 70) / 5) * 5, 90);
      carbsDisplay = `${wLo}–${wHi} g/h`;
    } else {
      carbsDisplay = `${carbLow}–${carbHigh} g/h`;
    }

    // Fluid: weight-based (approx 5-8ml/kg/h baseline, heat adjusted)
    let fluidDisplay = '';
    if (hasWeight) {
      const baseLo = Math.round(weight * (heat === 'indoor' ? 7 : heat === 'warm' ? 6 : 5) / 50) * 50;
      const baseHi = Math.round(weight * (heat === 'indoor' ? 12 : heat === 'warm' ? 10 : 8) / 50) * 50;
      const intMod = intensity >= 4 ? 1.2 : 1.0;
      fluidDisplay = `${Math.round(baseLo * intMod / 50) * 50}–${Math.round(baseHi * intMod / 50) * 50} ml/h`;
    } else {
      fluidDisplay = `${fluidLow}–${fluidHigh} ml/h`;
    }

    // Total carbs for the session
    let totalCarbsRow = '';
    if (carbLow > 0 && dur >= 60) {
      const nums = carbsDisplay.match(/\d+/g);
      if (nums && nums.length >= 2) {
        const totalLo = Math.round(+nums[0] * hours);
        const totalHi = Math.round(+nums[1] * hours);
        totalCarbsRow = `<div class="tool-result"><div class="tool-result-label">Gesamt Carbs</div><div class="tool-result-value">${totalLo}–${totalHi} g</div><div class="tool-result-sub">für ${dur} Minuten</div></div>`;
      }
    }

    // Older athlete note
    if (isOlderAthlete) {
      text += ' Ab 45+ lohnt es sich, Elektrolyte und Flüssigkeit bewusster zu managen — die Durstempfindung lässt im Alter nach.';
    }

    // Carb type for DuringFuel
    const dfCarbTypeHTML = carbLow > 0 ? `
      <div class="carb-type-box" style="margin-top:12px;">
        <div class="carb-type-label"><strong>⚡ Während des Trainings: nur schnelle Carbs</strong></div>
        <div class="carb-type-tip">Der Magen kann während Belastung weniger Fett und Ballaststoffe verarbeiten. Schnelle, einfache Carbs werden am schnellsten absorbiert.</div>
        <div class="carb-type-row">
          <div class="carb-col">
            <div class="carb-col-label">⚡ Empfohlen</div>
            <div class="carb-col-examples">Sportgetränk · Gels · Gummibärchen · Banane · Reiskuchen · Datteln · Weißbrot mit Honig</div>
          </div>
          <div class="carb-col">
            <div class="carb-col-label">⛔ Vermeiden</div>
            <div class="carb-col-examples">Vollkorn · Hülsenfrüchte · Nüsse · Ballaststoffreiche Snacks · Milchprodukte · Fettiges</div>
          </div>
        </div>
        ${dur >= 150 ? '<div class="carb-type-tip" style="margin-top:10px;margin-bottom:0;">💡 Bei langen Einheiten: Glukose + Fruktose kombinieren (z.B. Gel + Sportgetränk) — so kann der Darm bis zu 90 g/h aufnehmen statt nur 60 g.</div>' : ''}
      </div>` : '';

    document.getElementById('dfResults').innerHTML = `
      <div class="tool-result"><div class="tool-result-label">Carbs</div><div class="tool-result-value">${carbsDisplay}</div><div class="tool-result-sub">${hasWeight ? 'für ' + weight + ' kg' : 'Richtwert'}</div></div>
      ${totalCarbsRow}
      <div class="tool-result"><div class="tool-result-label">Flüssigkeit</div><div class="tool-result-value">${fluidDisplay}</div><div class="tool-result-sub">${hasWeight ? 'für ' + weight + ' kg' : 'grob pro Stunde'}</div></div>
      <div class="tool-result"><div class="tool-result-label">Elektrolyte</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;">${electrolytes}</div><div class="tool-result-sub">je nach Schweiß & Hitze</div></div>
    ` + dfCarbTypeHTML;
    document.getElementById('dfResults').classList.remove('hidden');
    document.getElementById('dfInterpretation').innerHTML = `<strong>Einordnung</strong><br>${text}`;
    document.getElementById('dfInterpretation').classList.remove('hidden');
    document.getElementById('dfDisclaimer').classList.remove('hidden');
    document.getElementById('dfScience').classList.remove('hidden');
  }

  function calculateHeatSweat() {
    const dur = +(document.getElementById('hsDuration').value || 0);
    const env = document.getElementById('hsEnvironment').value;
    const sweat = document.getElementById('hsSweat').value;
    const intensity = +(document.getElementById('hsIntensity').value || 2);
    if (!dur) { alert('Bitte eine Dauer eingeben.'); return; }

    let rateLow = 0.4, rateHigh = 0.7;
    if (env === 'hot' || env === 'indoor') { rateLow += 0.25; rateHigh += 0.45; }
    if (sweat === 'high' || sweat === 'salty') { rateLow += 0.2; rateHigh += 0.35; }
    if (intensity >= 4) { rateLow += 0.15; rateHigh += 0.25; }

    const hours = dur / 60;
    const totalLow = Math.round(rateLow * hours * 10) / 10;
    const totalHigh = Math.round(rateHigh * hours * 10) / 10;
    const drinkLow = Math.round(rateLow * 1000 / 50) * 50;
    const drinkHigh = Math.round(rateHigh * 1000 / 50) * 50;
    const salt = sweat === 'salty' || env === 'hot' || env === 'indoor' ? 'relevant' : 'optional';
    let text = 'Die Werte sind grobe Orientierung. Entscheidend ist, wie du dich fühlst und ob Gewicht, Durst, Kopfschmerz oder Salzränder auffallen.';
    if (env === 'indoor') text += ' Indoor unterschätzt man Schweißverlust oft massiv, weil der Fahrtwind fehlt.';
    if (sweat === 'salty') text += ' Salzränder sind ein Hinweis, Elektrolyte nicht komplett zu ignorieren.';

    document.getElementById('hsResults').innerHTML = `
      <div class="tool-result"><div class="tool-result-label">Schweißverlust</div><div class="tool-result-value">${totalLow}–${totalHigh} L</div><div class="tool-result-sub">für diese Einheit</div></div>
      <div class="tool-result"><div class="tool-result-label">Trinken</div><div class="tool-result-value">${drinkLow}–${drinkHigh} ml/h</div><div class="tool-result-sub">grobe Spanne</div></div>
      <div class="tool-result"><div class="tool-result-label">Salz</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;">${salt}</div><div class="tool-result-sub">bei viel Schweiß</div></div>`;
    document.getElementById('hsResults').classList.remove('hidden');
    document.getElementById('hsInterpretation').innerHTML = `<strong>Einordnung</strong><br>${text}`;
    document.getElementById('hsInterpretation').classList.remove('hidden');
    document.getElementById('hsDisclaimer').classList.remove('hidden');
    document.getElementById('hsScience').classList.remove('hidden');
  }

  function calculateRecoveryCheck() {
    const sleep = document.getElementById('rcSleep').value;
    const fatigue = document.getElementById('rcFatigue').value;
    const muscles = document.getElementById('rcMuscles').value;
    const stress = document.getElementById('rcStress').value;

    let score = 0;
    if (sleep === 'bad') score += 2; else if (sleep === 'ok') score += 1;
    if (fatigue === 'empty') score += 3; else if (fatigue === 'tired') score += 2; else if (fatigue === 'normal') score += 1;
    if (muscles === 'pain') score += 4; else if (muscles === 'heavy') score += 2; else if (muscles === 'sore') score += 1;
    if (stress === 'high') score += 2; else if (stress === 'normal') score += 1;

    let readiness = 'bereit', suggestion = 'normal trainieren', text = 'Du wirkst insgesamt belastbar. Eine geplante Einheit ist plausibel, solange sie sich beim Warm-up gut anfühlt.';
    if (score >= 7) {
      readiness = 'vorsichtig';
      suggestion = muscles === 'pain' ? 'Pause / abklären' : 'locker oder Pause';
      text = muscles === 'pain'
        ? 'Schmerz ist kein normales Müdigkeitssignal. Heute wäre Zurückhaltung sinnvoll — nicht einfach wegtrainieren.'
        : 'Mehrere Signale sprechen für reduzierte Belastbarkeit. Locker bewegen, Zone 1–2 oder Pause wären heute plausibler als Intensität.';
    } else if (score >= 4) {
      readiness = 'mittel';
      suggestion = 'Umfang oder Intensität senken';
      text = 'Du bist nicht komplett platt, aber auch nicht frisch. Eine moderate Einheit kann passen; harte Intervalle oder schwere Max-Sätze eher kritisch prüfen.';
    }

    document.getElementById('rcResults').innerHTML = `
      <div class="tool-result"><div class="tool-result-label">Bereitschaft</div><div class="tool-result-value">${readiness}</div><div class="tool-result-sub">heutiges Signal</div></div>
      <div class="tool-result"><div class="tool-result-label">Vorschlag</div><div class="tool-result-value" style="font-size:1rem;font-family:'DM Sans',sans-serif;line-height:1.35;">${suggestion}</div><div class="tool-result-sub">für heute</div></div>
      <div class="tool-result"><div class="tool-result-label">Score</div><div class="tool-result-value">${score}/10</div><div class="tool-result-sub">grob, subjektiv</div></div>`;
    document.getElementById('rcResults').classList.remove('hidden');
    document.getElementById('rcInterpretation').innerHTML = `<strong>Einordnung</strong><br>${text}`;
    document.getElementById('rcInterpretation').classList.remove('hidden');
    document.getElementById('rcDisclaimer').classList.remove('hidden');
    document.getElementById('rcScience').classList.remove('hidden');
  }

  /* ── Hero Preview Rotation ── */
  const previewScenarios = [
    {
      ctx: '75 kg · 52 Min Sweetspot · moderat gegessen',
      icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#3d7a52" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><path d="M8 5v4M6 8h4"/></svg>`,
      protein: '38', carbs: '95', kcal: '640',
      meal: 'Reis + Hähnchen + Quark',
      sub: 'Schnell verfügbare Carbs, vollständiges Protein — passt hier gut.'
    },
    {
      ctx: '68 kg · 45 Min Laufen locker · wenig gegessen',
      icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#3d7a52" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2a1.5 1.5 0 1 1 0-3"/><path d="M7 5l2 2-2 5 3-2 1.5 3"/><path d="M5 14l1.5-3"/></svg>`,
      protein: '28', carbs: '55', kcal: '390',
      meal: 'Skyr-Bowl + Banane + Haferflocken',
      sub: 'Leichte Einheit, schnelle Kohlenhydrate, wenig Fett — reicht hier.'
    },
    {
      ctx: '82 kg · Krafttraining Hypertrophie · gut gegessen',
      icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#3d7a52" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h8M2 8h2M12 8h2M4 6v4M12 6v4"/></svg>`,
      protein: '48', carbs: '60', kcal: '520',
      meal: 'Magerquark + Haferflocken + Beeren',
      sub: 'Muskelaufbau braucht Protein jetzt — Carbs moderat, Fett minimal.'
    }
  ];

  let previewIdx = 0;
  let previewTimer = null;

  function setPreviewScenario(idx, animate = true) {
    const s = previewScenarios[idx];
    const scenario = document.getElementById('previewScenario');
    const dots = document.querySelectorAll('.preview-dot');

    dots.forEach((d, i) => d.classList.toggle('active', i === idx));

    if (!animate) {
      applyScenario(s);
      return;
    }

    scenario.classList.add('fade-out');
    setTimeout(() => {
      applyScenario(s);
      scenario.classList.remove('fade-out');
    }, 380);
  }

  function applyScenario(s) {
    document.getElementById('previewCtxText').textContent = s.ctx;
    document.getElementById('previewProtein').textContent = s.protein;
    document.getElementById('previewCarbs').textContent = s.carbs;
    document.getElementById('previewKcal').textContent = s.kcal;
    document.getElementById('previewMealIcon').innerHTML = s.icon;
    document.getElementById('previewMealTitle').textContent = s.meal;
    document.getElementById('previewMealSub').textContent = s.sub;
  }

  function startPreviewRotation() {
    previewTimer = setInterval(() => {
      previewIdx = (previewIdx + 1) % previewScenarios.length;
      setPreviewScenario(previewIdx);
    }, 4500);
  }

  document.querySelectorAll('.preview-dot').forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(previewTimer);
      previewIdx = parseInt(dot.dataset.idx);
      setPreviewScenario(previewIdx);
      startPreviewRotation();
    });
  });

  startPreviewRotation();

</script>
</body>
</html>
